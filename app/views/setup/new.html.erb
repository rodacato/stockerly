<% content_for(:title, "Setup | Stockerly") %>

<main class="grow flex items-center justify-center p-4 py-12">
  <div class="w-full max-w-4xl bg-white dark:bg-slate-900 rounded-xl overflow-hidden shadow-xl flex flex-col md:flex-row min-h-[600px]">
    <%# Left Side: Branding %>
    <div class="hidden md:flex md:w-1/2 bg-primary relative overflow-hidden p-12 flex-col justify-between text-white">
      <div class="relative z-10">
        <div class="size-12 bg-white/20 rounded-lg flex items-center justify-center mb-8">
          <span class="material-symbols-outlined text-white text-3xl">settings</span>
        </div>
        <h1 class="text-3xl font-bold leading-tight mb-4">Welcome to Stockerly</h1>
        <p class="text-blue-100 text-lg">Let's set up your instance. Create your admin account to get started.</p>
      </div>
      <div class="relative z-10">
        <div class="space-y-3">
          <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-emerald-300">check_circle</span>
            <span class="text-sm text-blue-100">Configure market data API keys</span>
          </div>
          <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-emerald-300">check_circle</span>
            <span class="text-sm text-blue-100">Choose assets to track</span>
          </div>
          <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-emerald-300">check_circle</span>
            <span class="text-sm text-blue-100">Launch your first data sync</span>
          </div>
          <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-emerald-300">check_circle</span>
            <span class="text-sm text-blue-100">100% free & open source</span>
          </div>
        </div>
      </div>
      <%# Background pattern %>
      <div class="absolute inset-0 opacity-10 pointer-events-none">
        <svg width="100%" height="100%" viewBox="0 0 100 100" preserveAspectRatio="none">
          <path d="M0 100 L20 80 L40 90 L60 50 L80 70 L100 20 V100 H0 Z" fill="white"/>
        </svg>
      </div>
    </div>

    <%# Right Side: Setup Form %>
    <div class="w-full md:w-1/2 p-8 lg:p-12 flex flex-col justify-center">
      <div class="space-y-6">
        <div class="text-center md:text-left">
          <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Create Admin Account</h2>
          <p class="text-slate-500 dark:text-slate-400 text-sm mt-1">This will be the first user with full admin access.</p>
        </div>

        <%# Error Messages %>
        <% if @errors.present? %>
          <div class="p-3 rounded-lg bg-rose-50 dark:bg-rose-900/20 border border-rose-200 dark:border-rose-800 text-sm text-rose-700 dark:text-rose-400">
            <div class="flex items-center gap-2 mb-1">
              <span class="material-symbols-outlined text-lg">error</span>
              <span class="font-medium">Please fix the following errors:</span>
            </div>
            <ul class="list-disc pl-9 space-y-0.5">
              <% @errors.each do |field, messages| %>
                <% Array(messages).each do |message| %>
                  <li><%= field.to_s.humanize %> <%= message %></li>
                <% end %>
              <% end %>
            </ul>
          </div>
        <% end %>

        <%# Setup Form %>
        <%= form_with url: setup_path, method: :post, class: "space-y-4" do |f| %>
          <div>
            <label for="full_name" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">Full Name</label>
            <input type="text" id="full_name" name="full_name" autocomplete="name" placeholder="John Doe" required
                   class="w-full px-4 py-3 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all">
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">Email Address</label>
            <input type="email" id="email" name="email" autocomplete="email" placeholder="admin@yourcompany.com" required
                   class="w-full px-4 py-3 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all">
          </div>
          <div>
            <label for="password" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">Password</label>
            <input type="password" id="password" name="password" autocomplete="new-password" placeholder="Min. 8 characters" required
                   class="w-full px-4 py-3 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all">
          </div>
          <div>
            <label for="password_confirmation" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">Confirm Password</label>
            <input type="password" id="password_confirmation" name="password_confirmation" autocomplete="new-password" placeholder="Repeat your password" required
                   class="w-full px-4 py-3 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all">
          </div>
          <button type="submit" class="w-full bg-primary hover:bg-primary/90 text-white font-bold py-3 px-4 rounded-lg transition-colors shadow-md shadow-primary/20 flex items-center justify-center gap-2">
            <span>Create Admin & Continue</span>
            <span class="material-symbols-outlined text-lg">arrow_forward</span>
          </button>
        <% end %>
      </div>
    </div>
  </div>
</main>
