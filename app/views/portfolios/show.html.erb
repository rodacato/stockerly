<%# Portfolio — investment portfolio overview %>
<% if @positions.blank? && @tab == "open" %>
  <%= render "components/empty_state", icon: "account_balance_wallet", title: "No positions yet", description: "Add your first position to start tracking your portfolio performance.", cta_text: "Explore Markets", cta_path: market_path %>
<% else %>

<%# Header with action buttons %>
<div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-8">
  <div>
    <h2 class="text-3xl font-extrabold tracking-tight text-slate-900 dark:text-white">Investment Portfolio</h2>
    <p class="mt-1 text-slate-500 dark:text-slate-400">Track and manage your equity positions in real-time</p>
  </div>
  <div class="flex gap-3">
    <button class="px-4 py-2.5 border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-sm font-bold text-slate-700 dark:text-slate-300 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-700 transition-colors shadow-sm">
      <span class="material-symbols-outlined text-sm align-middle mr-1">swap_horiz</span>
      Buy / Sell
    </button>
    <button class="px-4 py-2.5 bg-primary text-white text-sm font-bold rounded-lg hover:bg-primary/90 transition-colors shadow-sm">
      <span class="material-symbols-outlined text-sm align-middle mr-1">add</span>
      Add Position
    </button>
  </div>
</div>

<%# 3 Summary Stat Cards %>
<% ug = @summary.unrealized_gain %>
<% dg = @summary.day_gain %>
<% bp_pct = @summary.total_value.positive? ? (@summary.buying_power / @summary.total_value * 100) : 0 %>
<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
  <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 p-6 shadow-sm">
    <p class="text-sm font-medium text-slate-500 dark:text-slate-400">Total Portfolio Value</p>
    <div class="mt-2 flex items-baseline gap-2">
      <span class="text-2xl font-black tracking-tight text-slate-900 dark:text-white"><%= number_to_currency(@summary.total_value) %></span>
      <span class="inline-flex items-center gap-0.5 px-2 py-0.5 rounded-full text-xs font-bold <%= dg.positive? ? 'bg-emerald-50 dark:bg-emerald-900/30 text-emerald-600 dark:text-emerald-400' : 'bg-rose-50 dark:bg-rose-900/30 text-rose-600 dark:text-rose-400' %>">
        <span class="material-symbols-outlined text-sm"><%= dg.positive? ? 'trending_up' : 'trending_down' %></span>
        <%= dg.positive? ? '+' : '' %><%= number_to_percentage(dg.percent, precision: 1) %>
      </span>
    </div>
    <p class="text-xs text-slate-400 mt-2">Domestic: <%= number_to_currency(@summary.domestic_value) %> &bull; International: <%= number_to_currency(@summary.international_value) %></p>
  </div>

  <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 p-6 shadow-sm">
    <p class="text-sm font-medium text-slate-500 dark:text-slate-400">Total Unrealized Gain/Loss</p>
    <div class="mt-2 flex items-baseline gap-2">
      <span class="text-2xl font-black tracking-tight <%= ug.positive? ? 'text-emerald-600 dark:text-emerald-400' : 'text-rose-600 dark:text-rose-400' %>"><%= ug.positive? ? '+' : '' %><%= number_to_currency(ug.absolute) %></span>
      <span class="inline-flex items-center gap-0.5 px-2 py-0.5 rounded-full text-xs font-bold <%= ug.positive? ? 'bg-emerald-50 dark:bg-emerald-900/30 text-emerald-600 dark:text-emerald-400' : 'bg-rose-50 dark:bg-rose-900/30 text-rose-600 dark:text-rose-400' %>">
        <%= ug.positive? ? '+' : '' %><%= number_to_percentage(ug.percent, precision: 1) %>
      </span>
    </div>
    <p class="text-xs text-slate-400 mt-2">Since <%= @portfolio.inception_date&.strftime("%b %d, %Y") %></p>
  </div>

  <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 p-6 shadow-sm">
    <p class="text-sm font-medium text-slate-500 dark:text-slate-400">Available Buying Power</p>
    <div class="mt-2 flex items-baseline gap-2">
      <span class="text-2xl font-black tracking-tight text-slate-900 dark:text-white"><%= number_to_currency(@summary.buying_power) %></span>
    </div>
    <p class="text-xs text-slate-400 mt-2"><%= number_to_percentage(bp_pct, precision: 1) %> of portfolio</p>
  </div>
</div>

<%# Portfolio Grid: Allocation (1/3) + Positions (2/3) %>
<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
  <%# Allocation Sidebar %>
  <%= render "portfolios/allocation_sidebar" %>

  <%# Positions Table %>
  <div class="lg:col-span-2">
    <%= render "portfolios/positions_table" %>
  </div>
</div>
<% end %>
