<%# Positions table with tabs (Open/Closed/Dividends) %>
<section class="rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 overflow-hidden shadow-sm">
  <%# Tabs header — uses query params for Turbo Drive navigation %>
  <div class="flex items-center border-b border-slate-100 dark:border-slate-800">
    <%= link_to portfolio_path(tab: "open"), class: "px-6 py-4 text-sm font-bold border-b-2 #{@tab == 'open' ? 'border-primary text-primary' : 'border-transparent text-slate-400 hover:text-slate-600'}" do %>
      Open Positions <span class="ml-1 text-xs bg-primary/10 text-primary px-1.5 py-0.5 rounded-full"><%= @portfolio.open_positions.size %></span>
    <% end %>
    <%= link_to portfolio_path(tab: "closed"), class: "px-6 py-4 text-sm font-medium border-b-2 #{@tab == 'closed' ? 'border-primary text-primary' : 'border-transparent text-slate-400 hover:text-slate-600'}" do %>
      Closed Positions
    <% end %>
    <%= link_to portfolio_path(tab: "dividends"), class: "px-6 py-4 text-sm font-medium border-b-2 #{@tab == 'dividends' ? 'border-primary text-primary' : 'border-transparent text-slate-400 hover:text-slate-600'}" do %>
      Dividend History
    <% end %>
    <%= link_to portfolio_path(tab: "trades"), class: "px-6 py-4 text-sm font-medium border-b-2 #{@tab == 'trades' ? 'border-primary text-primary' : 'border-transparent text-slate-400 hover:text-slate-600'}" do %>
      Trade Log
    <% end %>
  </div>

  <% if @tab == "trades" %>
    <%# Trade Log %>
    <% if @positions.present? %>
      <div class="overflow-x-auto">
        <table class="w-full text-left">
          <thead class="bg-slate-50 dark:bg-slate-800/50 text-xs uppercase tracking-wider text-slate-500">
            <tr>
              <th class="px-6 py-3 font-semibold">Date</th>
              <th class="px-6 py-3 font-semibold">Asset</th>
              <th class="px-6 py-3 font-semibold text-center">Side</th>
              <th class="px-6 py-3 font-semibold text-right">Shares</th>
              <th class="px-6 py-3 font-semibold text-right">Price</th>
              <th class="px-6 py-3 font-semibold text-right">Total</th>
              <th class="px-6 py-3 font-semibold text-right">Fee</th>
            </tr>
          </thead>
          <tbody id="trade_history" class="divide-y divide-slate-100 dark:divide-slate-800">
            <% @positions.each do |trade| %>
              <%= render "trades/trade_row", trade: trade %>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <%= render "components/empty_state", icon: "swap_horiz", title: "No trades yet", description: "Use the form above to log your first trade." %>
    <% end %>
  <% elsif @tab == "dividends" %>
    <%# Upcoming Dividends %>
    <% if @upcoming_dividends.present? %>
      <div class="border-b border-slate-100 dark:border-slate-800">
        <div class="px-6 py-4 bg-emerald-50 dark:bg-emerald-900/20">
          <h3 class="text-sm font-bold text-emerald-700 dark:text-emerald-400 flex items-center gap-2">
            <span class="material-symbols-outlined text-base">event_upcoming</span>
            Upcoming Dividends
          </h3>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-left">
            <thead class="bg-slate-50 dark:bg-slate-800/50 text-xs uppercase tracking-wider text-slate-500">
              <tr>
                <th class="px-6 py-3 font-semibold">Asset</th>
                <th class="px-6 py-3 font-semibold text-center">Ex-Date</th>
                <th class="px-6 py-3 font-semibold text-center">Pay Date</th>
                <th class="px-6 py-3 font-semibold text-right">$/Share</th>
                <th class="px-6 py-3 font-semibold text-right">Shares</th>
                <th class="px-6 py-3 font-semibold text-right">Expected Payout</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
              <% @upcoming_dividends.each do |ud| %>
                <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/30 transition-colors">
                  <td class="px-6 py-4 text-sm font-bold text-slate-900 dark:text-white"><%= ud.asset.symbol %></td>
                  <td class="px-6 py-4 text-center text-sm text-slate-500"><%= ud.ex_date.strftime("%b %d, %Y") %></td>
                  <td class="px-6 py-4 text-center text-sm text-slate-500"><%= ud.pay_date&.strftime("%b %d, %Y") || "—" %></td>
                  <td class="px-6 py-4 text-right text-sm text-slate-900 dark:text-white"><%= number_to_currency(ud.amount_per_share, precision: 4) %></td>
                  <td class="px-6 py-4 text-right text-sm text-slate-900 dark:text-white"><%= ud.shares %></td>
                  <td class="px-6 py-4 text-right text-sm font-medium text-emerald-600"><%= number_to_currency(ud.expected_total) %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    <% end %>

    <%# Dividend History %>
    <% if @positions.present? %>
      <div class="overflow-x-auto">
        <table class="w-full text-left">
          <thead class="bg-slate-50 dark:bg-slate-800/50 text-xs uppercase tracking-wider text-slate-500">
            <tr>
              <th class="px-6 py-3 font-semibold">Asset</th>
              <th class="px-6 py-3 font-semibold text-center">Shares Held</th>
              <th class="px-6 py-3 font-semibold text-right">Amount</th>
              <th class="px-6 py-3 font-semibold text-right">Date</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
            <% @positions.each do |dp| %>
              <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/30 transition-colors">
                <td class="px-6 py-4 text-sm font-bold text-slate-900 dark:text-white"><%= dp.dividend.asset.symbol %></td>
                <td class="px-6 py-4 text-center text-sm text-slate-900 dark:text-white"><%= dp.shares_held %></td>
                <td class="px-6 py-4 text-right text-sm font-medium text-emerald-600"><%= number_to_currency(dp.total_amount) %></td>
                <td class="px-6 py-4 text-right text-sm text-slate-500"><%= dp.created_at.strftime("%b %d, %Y") %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <%= render "components/empty_state", icon: "payments", title: "No dividend history yet", description: "Dividend payments will appear here." %>
    <% end %>
  <% else %>
    <%# Open or Closed Positions %>
    <% if @positions.present? %>
      <div class="overflow-x-auto">
        <table class="w-full text-left">
          <thead class="bg-slate-50 dark:bg-slate-800/50 text-xs uppercase tracking-wider text-slate-500">
            <tr>
              <th class="px-6 py-3 font-semibold">Ticker</th>
              <th class="px-6 py-3 font-semibold text-center">Shares</th>
              <th class="px-6 py-3 font-semibold text-right">Avg Cost</th>
              <th class="px-6 py-3 font-semibold text-right">Market Price</th>
              <th class="px-6 py-3 font-semibold text-right">Market Value</th>
              <th class="px-6 py-3 font-semibold text-right">Total Gain</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
            <% @positions.each do |pos| %>
              <% gain = pos.total_gain %>
              <% positive = gain >= 0 %>
              <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/30 transition-colors">
                <td class="px-6 py-4">
                  <div class="flex items-center gap-3">
                    <%= render "components/asset_badge", asset: pos.asset, size: "sm" %>
                    <div>
                      <div class="flex items-center gap-1.5">
                        <p class="text-sm font-bold text-slate-900 dark:text-white"><%= pos.asset.name %></p>
                        <% if pos.notes.present? %>
                          <span class="material-symbols-outlined text-sm text-slate-400" title="<%= pos.notes %>">sticky_note_2</span>
                        <% end %>
                      </div>
                      <div class="flex items-center gap-1 flex-wrap">
                        <p class="text-xs text-slate-500"><%= pos.currency %></p>
                        <% pos.labels.each do |label| %>
                          <span class="text-[10px] px-1.5 py-0.5 rounded-full bg-primary/10 text-primary font-medium"><%= label %></span>
                        <% end %>
                      </div>
                    </div>
                  </div>
                </td>
                <td class="px-6 py-4 text-center text-sm font-medium text-slate-900 dark:text-white"><%= pos.shares %></td>
                <td class="px-6 py-4 text-right text-sm text-slate-500"><%= number_to_currency(pos.avg_cost) %></td>
                <td class="px-6 py-4 text-right text-sm font-medium text-slate-900 dark:text-white"><%= number_to_currency(pos.asset.current_price) %></td>
                <td class="px-6 py-4 text-right text-sm font-medium text-slate-900 dark:text-white"><%= number_to_currency(pos.market_value) %></td>
                <td class="px-6 py-4 text-right">
                  <p class="text-sm font-bold <%= positive ? 'text-emerald-600 dark:text-emerald-400' : 'text-rose-600 dark:text-rose-400' %>">
                    <%= positive ? '+' : '' %><%= number_to_currency(gain) %>
                  </p>
                  <p class="text-[10px] font-medium <%= positive ? 'text-emerald-500' : 'text-rose-500' %>">
                    <%= positive ? '+' : '' %><%= number_to_percentage(pos.total_gain_percent, precision: 2) %>
                  </p>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <%= render "components/empty_state", icon: (@tab == "closed" ? "lock" : "trending_up"), title: "No #{@tab} positions yet", description: "Positions will appear here." %>
    <% end %>
  <% end %>
</section>
