<%# Earnings Calendar — monitor upcoming financial reports %>

<%# Header & Filters %>
<div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-8">
  <div>
    <h1 class="text-3xl font-black text-slate-900 dark:text-white tracking-tight">Earnings Calendar</h1>
    <p class="text-slate-500 dark:text-slate-400 mt-1">Monitor upcoming financial reports and quarterly results.</p>
  </div>
  <div class="flex flex-wrap items-center gap-4">
    <%# Toggle: My Watchlist / All Markets %>
    <div class="bg-white dark:bg-slate-900 p-1 rounded-lg border border-slate-200 dark:border-slate-800 flex shadow-sm">
      <%= link_to "My Watchlist", earnings_path(filter: "watchlist", date: @date),
          class: "px-4 py-1.5 text-sm font-semibold rounded-md transition-colors #{params[:filter] == 'watchlist' ? 'bg-primary text-white' : 'text-slate-600 dark:text-slate-400 hover:text-primary'}" %>
      <%= link_to "All Markets", earnings_path(date: @date),
          class: "px-4 py-1.5 text-sm font-semibold rounded-md transition-colors #{params[:filter].blank? ? 'bg-primary text-white' : 'text-slate-600 dark:text-slate-400 hover:text-primary'}" %>
    </div>

    <%# Month Navigator %>
    <div class="flex items-center gap-2 bg-white dark:bg-slate-900 p-1 rounded-lg border border-slate-200 dark:border-slate-800 shadow-sm">
      <%= link_to earnings_path(date: @date.prev_month, filter: params[:filter]),
          class: "p-1 hover:bg-slate-100 dark:hover:bg-slate-800 rounded text-slate-500" do %>
        <span class="material-symbols-outlined">chevron_left</span>
      <% end %>
      <span class="text-sm font-bold px-2 text-slate-700 dark:text-slate-300"><%= @date.strftime("%B %Y") %></span>
      <%= link_to earnings_path(date: @date.next_month, filter: params[:filter]),
          class: "p-1 hover:bg-slate-100 dark:hover:bg-slate-800 rounded text-slate-500" do %>
        <span class="material-symbols-outlined">chevron_right</span>
      <% end %>
    </div>
  </div>
</div>

<%# Main Layout: Sidebar + Calendar %>
<div class="flex flex-col lg:flex-row gap-8">
  <%# Left Sidebar %>
  <aside class="w-full lg:w-80 flex flex-col gap-6 shrink-0">
    <%= render "earnings/watchlist_priority" %>
    <%= render "earnings/pro_tips" %>
  </aside>

  <%# Calendar Grid %>
  <section class="flex-grow">
    <%= render "earnings/calendar_grid" %>

    <%# Legend %>
    <div class="mt-6 flex flex-wrap items-center gap-6 p-4 bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800">
      <div class="flex items-center gap-2">
        <div class="size-3 bg-primary rounded-full"></div>
        <span class="text-xs font-medium text-slate-600 dark:text-slate-400">Watchlist Active</span>
      </div>
      <div class="flex items-center gap-2">
        <div class="size-3 bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-full"></div>
        <span class="text-xs font-medium text-slate-600 dark:text-slate-400">General Market</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="material-symbols-outlined text-sm text-slate-400">wb_sunny</span>
        <span class="text-xs font-medium text-slate-600 dark:text-slate-400">Before Market Open</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="material-symbols-outlined text-sm text-slate-400">nights_stay</span>
        <span class="text-xs font-medium text-slate-600 dark:text-slate-400">After Market Close</span>
      </div>
    </div>
  </section>
</div>
