<%# Earnings Calendar Grid — real data from @events and @date %>
<%
  # Build lookup: day_number => [events]
  events_by_day = @events.group_by { |e| e.report_date.day }
  watchlist_asset_ids = @watchlist_events.map(&:asset_id)

  # Calendar math
  first_day = @date.beginning_of_month
  last_day  = @date.end_of_month
  start_date = first_day.beginning_of_week(:sunday)
  end_date   = last_day.end_of_week(:sunday)
%>

<div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden">
  <%# Day headers %>
  <div class="grid grid-cols-7 border-b border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-800/50">
    <% %w[Sun Mon Tue Wed Thu Fri Sat].each do |day| %>
      <div class="py-3 text-center text-[10px] font-black uppercase tracking-widest text-slate-500"><%= day %></div>
    <% end %>
  </div>

  <%# Calendar cells %>
  <div class="grid grid-cols-7">
    <% (start_date..end_date).each do |cal_date| %>
      <% outside = cal_date.month != @date.month %>
      <% day_events = outside ? [] : (events_by_day[cal_date.day] || []) %>
      <% has_watchlist = day_events.any? { |e| watchlist_asset_ids.include?(e.asset_id) } %>

      <div class="min-h-[120px] border-r border-b border-slate-200 dark:border-slate-800 p-2 <%= outside ? 'text-slate-400 bg-slate-50/30 dark:bg-slate-900/50' : (has_watchlist ? 'bg-primary/5' : '') %>">
        <span class="text-sm font-bold <%= has_watchlist ? 'text-primary' : (outside ? 'text-slate-400' : 'text-slate-800 dark:text-slate-200') %>"><%= cal_date.day %></span>

        <% if day_events.any? %>
          <div class="mt-2 flex flex-col gap-1">
            <% day_events.each do |event| %>
              <% in_watchlist = watchlist_asset_ids.include?(event.asset_id) %>
              <% timing_label = event.before_market_open? ? "BMO" : "AMC" %>
              <% if in_watchlist %>
                <div class="flex items-center justify-between bg-primary/20 text-primary text-[9px] font-bold px-1.5 py-0.5 rounded">
                  <span><%= event.asset.symbol %></span>
                  <span class="material-symbols-outlined text-[10px]">star</span>
                </div>
              <% else %>
                <span class="text-[9px] font-bold bg-slate-100 dark:bg-slate-800 px-1.5 py-0.5 rounded text-slate-600 dark:text-slate-400"><%= event.asset.symbol %> (<%= timing_label %>)</span>
              <% end %>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
