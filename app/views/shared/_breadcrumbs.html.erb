<%# Usage: render "shared/breadcrumbs", crumbs: [["Home", root_path], ["Privacy Policy"]] %>
<% crumbs = local_assigns[:crumbs] || [] %>
<nav class="flex mb-4 text-sm text-slate-500 dark:text-slate-400 no-print" aria-label="Breadcrumb">
  <ol class="flex items-center gap-1">
    <li>
      <%= link_to "Home", root_path, class: "hover:text-primary transition-colors" %>
    </li>
    <% Array(crumbs).each do |crumb| %>
      <li class="flex items-center gap-1">
        <span class="mx-1">/</span>
        <% if crumb.is_a?(Array) && crumb.length == 2 %>
          <%= link_to crumb[0], crumb[1], class: "hover:text-primary transition-colors" %>
        <% else %>
          <span class="text-slate-900 dark:text-slate-200 font-medium"><%= crumb.is_a?(Array) ? crumb[0] : crumb %></span>
        <% end %>
      </li>
    <% end %>
  </ol>
</nav>
