<aside class="fixed inset-y-0 left-0 w-64 bg-white dark:bg-slate-900 border-r border-slate-200 dark:border-slate-800 flex flex-col z-40">
  <%# Logo %>
  <div class="h-16 flex items-center gap-2.5 px-6 border-b border-slate-200 dark:border-slate-800">
    <%= link_to admin_assets_path, class: "flex items-center gap-2.5" do %>
      <span class="material-symbols-outlined text-3xl text-primary">query_stats</span>
      <div>
        <span class="text-lg font-bold tracking-tight text-slate-900 dark:text-white">Stockerly</span>
        <span class="block text-[10px] font-medium text-slate-400 -mt-1">Admin Console</span>
      </div>
    <% end %>
  </div>

  <%# Navigation %>
  <nav class="flex-1 px-4 py-6 space-y-6 overflow-y-auto">
    <%# Admin Menu Section %>
    <div>
      <p class="px-3 mb-2 text-[11px] font-bold uppercase tracking-wider text-slate-400">Admin Menu</p>
      <div class="space-y-1">
        <% [
          ["Assets", admin_assets_path, "database"],
          ["Logs", admin_logs_path, "receipt_long"],
          ["Users", admin_users_path, "group"]
        ].each do |label, path, icon| %>
          <%= link_to path, class: "flex items-center gap-3 px-3 py-2.5 text-sm font-medium rounded-lg transition-colors #{admin_nav_active?(path)}" do %>
            <span class="material-symbols-outlined text-xl"><%= icon %></span>
            <%= label %>
          <% end %>
        <% end %>
      </div>
    </div>

    <%# System Section %>
    <div>
      <p class="px-3 mb-2 text-[11px] font-bold uppercase tracking-wider text-slate-400">System</p>
      <div class="space-y-1">
        <% [
          ["Settings", "#", "settings"],
          ["Support", "#", "help"]
        ].each do |label, path, icon| %>
          <%= link_to path, class: "flex items-center gap-3 px-3 py-2.5 text-sm font-medium rounded-lg text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors" do %>
            <span class="material-symbols-outlined text-xl"><%= icon %></span>
            <%= label %>
          <% end %>
        <% end %>
      </div>
    </div>
  </nav>

  <%# Admin User Card %>
  <div class="border-t border-slate-200 dark:border-slate-800 p-4">
    <div class="flex items-center gap-3">
      <div class="size-9 rounded-full bg-primary/10 flex items-center justify-center">
        <span class="text-sm font-bold text-primary"><%= current_user.full_name.split.map(&:first).join.upcase[0..1] %></span>
      </div>
      <div class="flex-1 min-w-0">
        <p class="text-sm font-bold text-slate-900 dark:text-white truncate"><%= current_user.full_name %></p>
        <p class="text-xs text-slate-400 truncate"><%= current_user.email %></p>
      </div>
    </div>
  </div>
</aside>
