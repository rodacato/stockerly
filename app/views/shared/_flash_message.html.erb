<% css_class = type.to_s == "notice" ? "bg-green-50 border-green-200 text-green-800 dark:bg-green-900/20 dark:border-green-800 dark:text-green-300" : "bg-red-50 border-red-200 text-red-800 dark:bg-red-900/20 dark:border-red-800 dark:text-red-300" %>
<div class="border rounded-lg px-4 py-3 shadow-lg <%= css_class %>"
     style="pointer-events: auto;"
     data-controller="flash"
     data-flash-dismiss-after-value="5000">
  <div class="flex items-center gap-3">
    <span class="material-symbols-outlined text-lg">
      <%= type.to_s == "notice" ? "check_circle" : "error" %>
    </span>
    <p class="text-sm font-medium flex-1"><%= message %></p>
    <button data-action="click->flash#dismiss" class="opacity-70 hover:opacity-100 transition-opacity">
      <span class="material-symbols-outlined text-lg">close</span>
    </button>
  </div>
</div>
