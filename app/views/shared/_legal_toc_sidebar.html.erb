<%# Usage: render "shared/legal_toc_sidebar", sections: [{ id: "intro", icon: "info", title: "Introduction", active: true }] %>
<% sections = local_assigns[:sections] || [] %>
<div class="sticky top-24 space-y-2">
  <h3 class="text-xs font-bold uppercase tracking-widest text-slate-400 mb-4 px-3">Table of Contents</h3>
  <% Array(sections).each do |section| %>
    <% active_class = section[:active] ? "bg-primary/10 text-primary font-semibold" : "hover:bg-slate-100 dark:hover:bg-slate-800 text-slate-600 dark:text-slate-400 font-medium" %>
    <a href="#<%= section[:id] %>" class="flex items-center gap-3 px-3 py-2 rounded-lg transition-all <%= active_class %>">
      <span class="material-symbols-outlined text-xl"><%= section[:icon] %></span>
      <%= section[:title] %>
    </a>
  <% end %>
</div>
