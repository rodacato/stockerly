<%# Turbo Stream target for prepending new notifications %>
<div class="flex gap-4 px-4 py-4 bg-primary/5 dark:bg-primary/10 hover:bg-primary/10 dark:hover:bg-primary/20 transition-colors border-b border-slate-50 dark:border-slate-800 cursor-pointer"
     data-notification-target="item">
  <div class="shrink-0 flex items-center justify-center size-10 rounded-full <%= notification_icon_style(notification) %>">
    <span class="material-symbols-outlined"><%= notification_icon(notification) %></span>
  </div>
  <div class="flex flex-col flex-1">
    <div class="flex items-center justify-between">
      <p class="text-slate-900 dark:text-slate-100 font-semibold text-sm leading-tight"><%= notification.title %></p>
      <span class="text-slate-400 text-[11px]">just now</span>
    </div>
    <% if notification.body.present? %>
      <p class="text-slate-600 dark:text-slate-400 text-sm mt-1 leading-normal"><%= notification.body %></p>
    <% end %>
    <div class="mt-2 flex items-center gap-1">
      <div class="size-2 rounded-full bg-primary"></div>
      <span class="text-[10px] text-primary font-bold uppercase tracking-tight"><%= notification.notification_type.humanize %></span>
    </div>
  </div>
</div>
