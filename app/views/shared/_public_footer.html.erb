<footer class="bg-slate-50 dark:bg-slate-900 border-t border-slate-200 dark:border-slate-800 pt-8 pb-6">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-8 mb-8">
      <%# Brand %>
      <div class="shrink-0">
        <%= link_to root_path, class: "flex items-center gap-2 mb-3" do %>
          <img src="/logo_light.svg" alt="Stockerly" class="h-6 dark:hidden">
          <img src="/logo_dark.svg" alt="Stockerly" class="h-6 hidden dark:block">
        <% end %>
        <p class="text-slate-500 dark:text-slate-400 text-xs max-w-xs leading-relaxed">
          Open Source Market Intelligence Platform.<br>Private by Design. Data-Driven by Nature.
        </p>
      </div>

      <%# Links %>
      <div class="flex flex-wrap gap-x-16 gap-y-6">
        <div>
          <h4 class="text-xs font-bold text-slate-900 dark:text-white uppercase tracking-wider mb-3">Platform</h4>
          <ul class="space-y-2">
            <li><%= link_to "Trend Explorer", trends_path, class: "text-xs text-slate-500 dark:text-slate-400 hover:text-primary transition-colors" %></li>
            <li><%= link_to "Open Source", open_source_path, class: "text-xs text-slate-500 dark:text-slate-400 hover:text-primary transition-colors" %></li>
          </ul>
        </div>

        <div>
          <h4 class="text-xs font-bold text-slate-900 dark:text-white uppercase tracking-wider mb-3">Company</h4>
          <ul class="space-y-2">
            <li><%= link_to "About Us", open_source_path, class: "text-xs text-slate-500 dark:text-slate-400 hover:text-primary transition-colors" %></li>
            <li><a href="https://github.com/rodacato/stockerly" target="_blank" rel="noopener" class="text-xs text-slate-500 dark:text-slate-400 hover:text-primary transition-colors">GitHub</a></li>
          </ul>
        </div>

        <div>
          <h4 class="text-xs font-bold text-slate-900 dark:text-white uppercase tracking-wider mb-3">Legal</h4>
          <ul class="space-y-2">
            <li><%= link_to "Privacy Policy", privacy_path, class: "text-xs text-slate-500 dark:text-slate-400 hover:text-primary transition-colors" %></li>
            <li><%= link_to "Terms of Service", terms_path, class: "text-xs text-slate-500 dark:text-slate-400 hover:text-primary transition-colors" %></li>
            <li><%= link_to "Risk Disclosure", risk_disclosure_path, class: "text-xs text-slate-500 dark:text-slate-400 hover:text-primary transition-colors" %></li>
          </ul>
        </div>
      </div>
    </div>

    <%# Bottom bar %>
    <div class="pt-6 border-t border-slate-200 dark:border-slate-800 flex flex-col sm:flex-row justify-between items-center gap-3">
      <p class="text-[11px] text-slate-400 dark:text-slate-500">
        &copy; <%= Date.current.year %> Stockerly. Open source under MIT License. Market data for informational purposes only.
      </p>
      <a href="https://github.com/rodacato/stockerly" target="_blank" rel="noopener" class="text-slate-400 hover:text-primary transition-colors" aria-label="GitHub">
        <svg class="h-4 w-4 fill-current" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
      </a>
    </div>
  </div>
</footer>
