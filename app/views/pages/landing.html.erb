<% content_for(:title, "Stockerly | Master the Markets with Data-Driven Trends") %>

<%# ===== Hero Section ===== %>
<section class="relative pt-16 pb-20 lg:pt-24 lg:pb-32 overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div class="z-10">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 text-primary text-xs font-bold uppercase tracking-wider mb-6">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-primary"></span>
          </span>
          Live Market Updates
        </div>
        <h1 class="text-5xl lg:text-7xl font-black text-slate-900 dark:text-white leading-[1.1] mb-6 tracking-tight">
          Master the Markets with <span class="text-primary">Data-Driven</span> Trends
        </h1>
        <p class="text-lg text-slate-600 dark:text-slate-400 mb-10 max-w-xl leading-relaxed">
          Leverage advanced algorithms and proprietary AI indicators to identify emerging opportunities before the crowd. Professional tools for the modern investor.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <%= link_to register_path, class: "bg-primary text-white px-8 py-4 text-base font-bold rounded-lg hover:scale-[1.02] active:scale-95 shadow-lg shadow-primary/20 transition-all text-center" do %>
            Get Started Now
          <% end %>
          <%= link_to trends_path, class: "bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-slate-900 dark:text-white px-8 py-4 text-base font-bold rounded-lg hover:bg-slate-50 dark:hover:bg-slate-700 transition-all text-center" do %>
            Explore Markets
          <% end %>
        </div>
        <div class="mt-8 flex items-center gap-4">
          <div class="flex -space-x-3">
            <div class="w-10 h-10 rounded-full border-2 border-white dark:border-slate-900 bg-primary/20 flex items-center justify-center text-primary text-xs font-bold">JD</div>
            <div class="w-10 h-10 rounded-full border-2 border-white dark:border-slate-900 bg-primary/30 flex items-center justify-center text-primary text-xs font-bold">SK</div>
            <div class="w-10 h-10 rounded-full border-2 border-white dark:border-slate-900 bg-primary/40 flex items-center justify-center text-primary text-xs font-bold">MR</div>
          </div>
          <p class="text-sm text-slate-500 dark:text-slate-400">
            <span class="font-bold text-slate-900 dark:text-white">50,000+</span> traders joined this month
          </p>
        </div>
      </div>

      <%# Browser mockup %>
      <div class="relative lg:h-[600px] flex items-center justify-center">
        <div class="absolute inset-0 bg-primary/5 rounded-3xl blur-3xl transform rotate-3 scale-95"></div>
        <div class="relative bg-white dark:bg-slate-900 p-4 rounded-xl shadow-2xl border border-slate-200 dark:border-slate-800 w-full max-w-lg aspect-[4/3] overflow-hidden">
          <div class="flex items-center justify-between mb-6 border-b border-slate-100 dark:border-slate-800 pb-4">
            <div class="flex gap-1.5">
              <div class="w-3 h-3 rounded-full bg-red-400"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
              <div class="w-3 h-3 rounded-full bg-green-400"></div>
            </div>
            <div class="text-xs font-semibold text-slate-400">MARKET_DASHBOARD_V2</div>
          </div>
          <div class="space-y-4">
            <div class="h-8 w-1/3 bg-slate-100 dark:bg-slate-800 rounded"></div>
            <div class="h-32 w-full bg-gradient-to-tr from-primary/10 to-transparent border border-primary/20 rounded-lg flex items-end p-2 gap-1">
              <div class="w-full bg-primary/40 h-1/2 rounded-t"></div>
              <div class="w-full bg-primary/60 h-2/3 rounded-t"></div>
              <div class="w-full bg-primary/40 h-1/3 rounded-t"></div>
              <div class="w-full bg-primary/80 h-4/5 rounded-t"></div>
              <div class="w-full bg-primary/50 h-3/5 rounded-t"></div>
              <div class="w-full bg-primary/90 h-full rounded-t"></div>
            </div>
            <div class="grid grid-cols-2 gap-4">
              <div class="h-16 bg-slate-50 dark:bg-slate-800/50 rounded-lg border border-slate-100 dark:border-slate-800 p-3">
                <div class="h-2 w-12 bg-slate-200 dark:bg-slate-700 rounded mb-2"></div>
                <div class="h-4 w-20 bg-primary/20 rounded"></div>
              </div>
              <div class="h-16 bg-slate-50 dark:bg-slate-800/50 rounded-lg border border-slate-100 dark:border-slate-800 p-3">
                <div class="h-2 w-12 bg-slate-200 dark:bg-slate-700 rounded mb-2"></div>
                <div class="h-4 w-20 bg-green-400/20 rounded"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%# ===== Social Proof Bar ===== %>
<section class="py-12 border-y border-slate-200 dark:border-slate-800 bg-white dark:bg-background-dark/30">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <p class="text-center text-sm font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-widest mb-8">Trusted by industry leading institutions</p>
    <div class="flex flex-wrap justify-center items-center gap-12 opacity-50 grayscale hover:grayscale-0 transition-all duration-500">
      <div class="flex items-center gap-2">
        <span class="material-symbols-outlined text-3xl">account_balance</span>
        <span class="font-bold text-xl">GlobalBank</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="material-symbols-outlined text-3xl">monitoring</span>
        <span class="font-bold text-xl">DataCore</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="material-symbols-outlined text-3xl">token</span>
        <span class="font-bold text-xl">FinStream</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="material-symbols-outlined text-3xl">assured_workload</span>
        <span class="font-bold text-xl">PrimeInvest</span>
      </div>
    </div>
  </div>
</section>

<%# ===== Features Section ===== %>
<section class="py-24 lg:py-32 bg-slate-50 dark:bg-slate-900/50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl lg:text-5xl font-black text-slate-900 dark:text-white mb-4">Powerful Features for Smarter Investing</h2>
      <p class="text-lg text-slate-600 dark:text-slate-400 leading-relaxed">Our platform provides the institutional-grade tools you need to stay ahead of rapid market movements.</p>
    </div>
    <div class="grid md:grid-cols-3 gap-8">
      <%= render "components/feature_card",
        icon: "trending_up",
        title: "Trend Analysis",
        description: "Identify high-probability setups with our proprietary AI indicators that filter out market noise and focus on real volume." %>
      <%= render "components/feature_card",
        icon: "pie_chart",
        title: "Portfolio Management",
        description: "Track performance, diversification, and risk metrics in real-time across all your brokerage accounts in one unified dashboard." %>
      <%= render "components/feature_card",
        icon: "notifications_active",
        title: "Smart Alerts",
        description: "Never miss a critical move with customizable price action and technical trend notifications delivered straight to your devices." %>
    </div>
  </div>
</section>

<%# ===== Stats Section ===== %>
<section class="py-20 bg-primary text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 text-center">
      <div>
        <p class="text-4xl lg:text-5xl font-black mb-2">$4.2B</p>
        <p class="text-white/70 text-sm font-medium uppercase tracking-widest">Assets Tracked</p>
      </div>
      <div>
        <p class="text-4xl lg:text-5xl font-black mb-2">50K+</p>
        <p class="text-white/70 text-sm font-medium uppercase tracking-widest">Active Traders</p>
      </div>
      <div>
        <p class="text-4xl lg:text-5xl font-black mb-2">99.9%</p>
        <p class="text-white/70 text-sm font-medium uppercase tracking-widest">System Uptime</p>
      </div>
      <div>
        <p class="text-4xl lg:text-5xl font-black mb-2">24/7</p>
        <p class="text-white/70 text-sm font-medium uppercase tracking-widest">Live Monitoring</p>
      </div>
    </div>
  </div>
</section>

<%# ===== CTA Section ===== %>
<section class="py-24 bg-white dark:bg-background-dark">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="bg-slate-900 dark:bg-slate-800 rounded-3xl p-8 lg:p-16 text-center relative overflow-hidden">
      <div class="absolute top-0 right-0 -mr-20 -mt-20 w-64 h-64 bg-primary/20 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-64 h-64 bg-primary/10 rounded-full blur-3xl"></div>
      <h2 class="text-3xl lg:text-5xl font-black text-white mb-6 relative z-10">Ready to transform your trading?</h2>
      <p class="text-lg text-slate-400 mb-10 max-w-2xl mx-auto relative z-10 leading-relaxed">
        Join thousands of investors using Stockerly to gain a competitive edge. Free and open source — start exploring now.
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4 relative z-10">
        <%= link_to register_path, class: "bg-primary text-white px-10 py-4 text-lg font-bold rounded-lg hover:scale-105 transition-all shadow-xl shadow-primary/30" do %>
          Get Started Free
        <% end %>
        <%= link_to open_source_path, class: "bg-white/10 hover:bg-white/20 text-white border border-white/20 px-10 py-4 text-lg font-bold rounded-lg transition-all backdrop-blur-sm" do %>
          View on GitHub
        <% end %>
      </div>
    </div>
  </div>
</section>
