<%# Profile — user settings and watchlist %>

<%# Profile Header %>
<%= render "profiles/profile_header" %>

<%# Main Grid: Settings (1/3) + Watchlist (2/3) %>
<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
  <%# Left Column: Personal Data & Settings %>
  <div class="space-y-8 lg:col-span-1">
    <%= render "profiles/personal_info_form" %>
    <%= render "profiles/account_settings" %>
  </div>

  <%# Right Column: Watchlist %>
  <div class="lg:col-span-2">
    <%= render "profiles/watchlist_table" %>
  </div>
</div>
