<%# My Watchlist table — data from @watchlist_items %>
<section class="bg-white dark:bg-slate-900 rounded-xl shadow-sm border border-slate-200 dark:border-slate-800 overflow-hidden">
  <div class="p-6 border-b border-slate-100 dark:border-slate-800 flex items-center justify-between">
    <h3 class="text-lg font-bold flex items-center gap-2 text-slate-900 dark:text-white">
      <span class="material-symbols-outlined text-primary">visibility</span>
      My Watchlist
    </h3>
    <%= link_to market_path, class: "text-sm bg-primary/10 text-primary px-4 py-2 rounded-lg font-bold hover:bg-primary/20 transition-all flex items-center gap-1" do %>
      <span class="material-symbols-outlined text-sm">add</span>
      Add Stock
    <% end %>
  </div>
  <% if @watchlist_items.present? %>
    <div class="overflow-x-auto">
      <table class="w-full text-left">
        <thead class="bg-slate-50 dark:bg-slate-800/50">
          <tr>
            <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Asset</th>
            <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Price</th>
            <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Change (24h)</th>
            <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Trend</th>
            <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider text-right">Action</th>
          </tr>
        </thead>
        <tbody id="watchlist_items" class="divide-y divide-slate-100 dark:divide-slate-800">
          <% @watchlist_items.each do |item| %>
            <% asset = item.asset %>
            <% change = asset.change_percent_24h || 0 %>
            <% positive = change >= 0 %>
            <%= tag.tr id: dom_id(item), class: "hover:bg-slate-50 dark:hover:bg-slate-800/30 transition-colors" do %>
              <td class="px-6 py-4">
                <div class="flex items-center gap-3">
                  <%= render "components/asset_badge", asset: asset, size: "sm", market_open: market_open_for(asset) %>
                  <div>
                    <p class="font-bold text-sm text-slate-900 dark:text-white"><%= asset.name %></p>
                    <p class="text-xs text-slate-500"><%= asset.exchange %></p>
                  </div>
                </div>
              </td>
              <td class="px-6 py-4">
                <p class="text-sm font-bold text-slate-900 dark:text-white"><%= number_to_currency(asset.current_price) %></p>
              </td>
              <td class="px-6 py-4">
                <span class="text-sm font-bold <%= positive ? 'text-emerald-500' : 'text-rose-500' %>"><%= positive ? '+' : '' %><%= number_to_percentage(change, precision: 2) %></span>
              </td>
              <td class="px-6 py-4">
                <% real_heights = sparkline_heights(asset) %>
                <%= render "components/sparkline", direction: positive ? :up : :down, heights: real_heights %>
              </td>
              <td class="px-6 py-4 text-right">
                <%= button_to watchlist_item_path(item), method: :delete, class: "text-slate-400 hover:text-red-500 transition-colors", data: { turbo_method: :delete } do %>
                  <span class="material-symbols-outlined">delete</span>
                <% end %>
              </td>
            <% end %>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="px-6 py-8 text-center text-sm text-slate-500">
      No assets in your watchlist. <%= link_to "Explore Markets", market_path, class: "text-primary font-semibold hover:underline" %>
    </div>
  <% end %>
  <div class="p-4 bg-slate-50 dark:bg-slate-800/50 text-center">
    <%= link_to "View Full Market Overview", market_path, class: "text-sm font-bold text-primary hover:text-primary/80 transition-all" %>
  </div>
</section>
