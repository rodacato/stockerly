<% content_for(:admin_page_title, "Assets") %>

<div class="space-y-6">
  <%# Header %>
  <div class="flex items-start justify-between">
    <div>
      <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Asset Management</h1>
      <p class="text-slate-500 mt-1">Overview and configuration of global Stocks & Crypto instruments.</p>
    </div>
    <div class="flex items-center gap-2">
      <%= button_to trigger_sync_all_admin_assets_path, method: :post,
          class: "inline-flex items-center gap-2 px-4 py-2 bg-primary text-white text-sm font-semibold rounded-lg hover:bg-primary/90 transition-colors" do %>
        <span class="material-symbols-outlined text-lg">sync</span>
        Sync All Assets
      <% end %>
    </div>
  </div>

  <%# KPI Cards %>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <%= render "components/admin_kpi_card", title: "Total Assets", value: number_with_delimiter(@total_count), icon: "database", color: :blue %>
    <%= render "components/admin_kpi_card", title: "Syncing Assets", value: @syncing_count.to_s, icon: "sync", color: :green, badge: "Active" %>
    <%= render "components/admin_kpi_card", title: "Listed", value: number_with_delimiter(@pagy.count), icon: "list", color: :amber %>
  </div>

  <%# Assets Table %>
  <%= render "admin/assets/assets_table" %>
</div>
