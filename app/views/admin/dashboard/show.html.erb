<% content_for(:admin_page_title, "Dashboard") %>

<div class="space-y-6">
  <%# Header %>
  <div>
    <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Admin Dashboard</h1>
    <p class="text-slate-500 mt-1">System overview and key metrics at a glance.</p>
  </div>

  <%# KPI Cards %>
  <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
    <%= render "components/admin_kpi_card", title: "Total Assets",   value: number_with_delimiter(@total_assets),   icon: "database",      color: :blue %>
    <%= render "components/admin_kpi_card", title: "Syncing Assets", value: @syncing_assets.to_s,                   icon: "sync",          color: :green, badge: "Active" %>
    <%= render "components/admin_kpi_card", title: "Total Users",    value: number_with_delimiter(@total_users),     icon: "group",         color: :amber %>
    <%= render "components/admin_kpi_card", title: "Errors (24h)",   value: @error_logs_24h.to_s,                   icon: "error_outline", color: :red %>
  </div>

  <%# Sync Operations %>
  <% if @sync_overview %>
    <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm p-6">
      <div class="flex items-center justify-between mb-4">
        <div>
          <h2 class="text-lg font-bold text-slate-900 dark:text-white">Sync Operations</h2>
          <p class="text-xs text-slate-500 mt-1">Last 24 hours activity overview</p>
        </div>
      </div>

      <%# Sync KPI mini-cards %>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-5">
        <div class="bg-emerald-50 dark:bg-emerald-900/20 rounded-lg p-3">
          <p class="text-xs text-emerald-600 dark:text-emerald-400 font-medium">Successful Syncs</p>
          <p class="text-xl font-bold text-emerald-700 dark:text-emerald-300"><%= @sync_overview[:sync_counts]["success"] || 0 %></p>
        </div>
        <div class="bg-red-50 dark:bg-red-900/20 rounded-lg p-3">
          <p class="text-xs text-red-600 dark:text-red-400 font-medium">Failed Syncs</p>
          <p class="text-xl font-bold text-red-700 dark:text-red-300"><%= @sync_overview[:sync_counts]["error"] || 0 %></p>
        </div>
        <div class="bg-blue-50 dark:bg-blue-900/20 rounded-lg p-3">
          <p class="text-xs text-blue-600 dark:text-blue-400 font-medium">Assets Syncing</p>
          <p class="text-xl font-bold text-blue-700 dark:text-blue-300"><%= @sync_overview[:status_counts]["active"] || 0 %></p>
        </div>
        <div class="bg-amber-50 dark:bg-amber-900/20 rounded-lg p-3">
          <p class="text-xs text-amber-600 dark:text-amber-400 font-medium">Stale Prices</p>
          <p class="text-xl font-bold text-amber-700 dark:text-amber-300"><%= @sync_overview[:stale_count] %></p>
        </div>
      </div>

      <%# Quick Actions — registry-driven %>
      <div class="flex flex-wrap gap-2 mb-5">
        <% @data_sources.each do |source| %>
          <%= button_to admin_trigger_data_source_path(key: source.key), method: :post,
              class: "inline-flex items-center gap-1.5 px-3 py-1.5 bg-#{source.color}-600 text-white text-xs font-semibold rounded-lg hover:bg-#{source.color}-700 transition-colors" do %>
            <span class="material-symbols-outlined text-sm"><%= source.icon %></span>
            Sync <%= source.name.split(" — ").first %>
          <% end %>
        <% end %>
      </div>

      <%# Recent Sync Errors %>
      <% if @sync_overview[:recent_errors].any? %>
        <h3 class="text-sm font-bold text-slate-700 dark:text-slate-300 mb-2">Recent Sync Errors</h3>
        <div class="space-y-2">
          <% @sync_overview[:recent_errors].each do |log| %>
            <div class="flex items-center justify-between p-2.5 rounded-lg bg-red-50 dark:bg-red-900/10 border border-red-100 dark:border-red-900/30">
              <div class="flex-1 min-w-0">
                <p class="text-xs font-medium text-red-800 dark:text-red-300 truncate"><%= log.task_name %></p>
                <p class="text-xs text-red-600 dark:text-red-400 truncate"><%= log.error_message %></p>
              </div>
              <span class="text-xs text-red-500 dark:text-red-400 whitespace-nowrap ml-3"><%= time_ago_in_words(log.created_at) %> ago</span>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-slate-400">No sync errors in the last 24 hours.</p>
      <% end %>
    </div>
  <% end %>

  <%# System Health %>
  <% if @health %>
    <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm p-6">
      <div class="mb-4">
        <h2 class="text-lg font-bold text-slate-900 dark:text-white">System Health</h2>
        <p class="text-xs text-slate-500 mt-1">Job queue, cache, and circuit breaker status</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <%# Job Queue Panel %>
        <div class="bg-slate-50 dark:bg-slate-800/50 rounded-lg p-4">
          <div class="flex items-center gap-2 mb-3">
            <span class="material-symbols-outlined text-lg text-blue-600 dark:text-blue-400">queue</span>
            <h3 class="text-sm font-bold text-slate-700 dark:text-slate-300">Job Queue</h3>
          </div>
          <div class="space-y-2">
            <div class="flex justify-between">
              <span class="text-xs text-slate-500">Pending</span>
              <span class="text-xs font-bold text-slate-900 dark:text-white"><%= @health[:queue_depth]&.to_s || "N/A" %></span>
            </div>
            <div class="flex justify-between">
              <span class="text-xs text-slate-500">In Progress</span>
              <span class="text-xs font-bold text-slate-900 dark:text-white"><%= @health[:in_progress_jobs]&.to_s || "N/A" %></span>
            </div>
            <div class="flex justify-between">
              <span class="text-xs text-slate-500">Scheduled</span>
              <span class="text-xs font-bold text-slate-900 dark:text-white"><%= @health[:scheduled_jobs]&.to_s || "N/A" %></span>
            </div>
            <div class="flex justify-between">
              <span class="text-xs text-slate-500">Failed</span>
              <% failed = @health[:failed_jobs] %>
              <span class="text-xs font-bold <%= failed && failed > 0 ? 'text-red-600 dark:text-red-400' : 'text-slate-900 dark:text-white' %>"><%= failed&.to_s || "N/A" %></span>
            </div>
            <div class="flex justify-between">
              <span class="text-xs text-slate-500">Workers</span>
              <span class="text-xs font-bold text-slate-900 dark:text-white"><%= @health[:queue_workers]&.to_s || "N/A" %></span>
            </div>
          </div>
        </div>

        <%# Cache Store Panel %>
        <div class="bg-slate-50 dark:bg-slate-800/50 rounded-lg p-4">
          <div class="flex items-center gap-2 mb-3">
            <span class="material-symbols-outlined text-lg text-emerald-600 dark:text-emerald-400">cached</span>
            <h3 class="text-sm font-bold text-slate-700 dark:text-slate-300">Cache Store</h3>
          </div>
          <div class="space-y-2">
            <div class="flex justify-between">
              <span class="text-xs text-slate-500">Entries</span>
              <span class="text-xs font-bold text-slate-900 dark:text-white"><%= @health[:cache_entries] ? number_with_delimiter(@health[:cache_entries]) : "N/A" %></span>
            </div>
            <div class="flex justify-between">
              <span class="text-xs text-slate-500">Size</span>
              <span class="text-xs font-bold text-slate-900 dark:text-white"><%= @health[:cache_byte_size] ? number_to_human_size(@health[:cache_byte_size]) : "N/A" %></span>
            </div>
          </div>
        </div>

        <%# Circuit Breakers Panel %>
        <div class="bg-slate-50 dark:bg-slate-800/50 rounded-lg p-4">
          <div class="flex items-center gap-2 mb-3">
            <span class="material-symbols-outlined text-lg text-amber-600 dark:text-amber-400">electric_bolt</span>
            <h3 class="text-sm font-bold text-slate-700 dark:text-slate-300">Circuit Breakers</h3>
          </div>
          <% if @health[:open_circuits_count] && @health[:open_circuits_count] > 0 %>
            <div class="bg-amber-50 dark:bg-amber-900/20 rounded-md p-2 mb-2">
              <p class="text-xs font-bold text-amber-700 dark:text-amber-300"><%= @health[:open_circuits_count] %> circuit(s) tripped in last 24h</p>
            </div>
          <% else %>
            <div class="bg-emerald-50 dark:bg-emerald-900/20 rounded-md p-2 mb-2">
              <p class="text-xs font-bold text-emerald-700 dark:text-emerald-300">All circuits healthy</p>
            </div>
          <% end %>
          <% if @health[:circuit_breaker_events].present? %>
            <div class="space-y-1.5 mt-2">
              <% @health[:circuit_breaker_events].limit(3).each do |event| %>
                <div class="flex items-center justify-between">
                  <span class="text-xs text-slate-600 dark:text-slate-400 truncate flex-1"><%= event.task_name.sub("Circuit Breaker: ", "") %></span>
                  <%= render "components/status_badge", status: event.severity %>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-xs text-slate-400 mt-2">No circuit breaker events in 24h.</p>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <%# AI Intelligence %>
  <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm p-6">
    <div class="flex items-center gap-2 mb-4">
      <span class="material-symbols-outlined text-xl text-violet-600 dark:text-violet-400">psychology</span>
      <h2 class="text-lg font-bold text-slate-900 dark:text-white">AI Intelligence</h2>
      <span class="px-1.5 py-0.5 rounded text-[9px] font-bold bg-violet-100 text-violet-700 dark:bg-violet-900/30 dark:text-violet-300">Optional</span>
    </div>

    <% ai_integration = Integration.find_by(provider_name: "AI Intelligence") %>
    <% if ai_integration %>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
        <div class="bg-violet-50 dark:bg-violet-900/20 rounded-lg p-3">
          <p class="text-xs text-violet-600 dark:text-violet-400 font-medium">Provider</p>
          <p class="text-sm font-bold text-violet-700 dark:text-violet-300 capitalize"><%= ai_integration.setting("provider") || "anthropic" %></p>
        </div>
        <div class="bg-violet-50 dark:bg-violet-900/20 rounded-lg p-3">
          <p class="text-xs text-violet-600 dark:text-violet-400 font-medium">Model</p>
          <p class="text-sm font-bold text-violet-700 dark:text-violet-300 truncate"><%= ai_integration.setting("model") || "default" %></p>
        </div>
        <div class="bg-violet-50 dark:bg-violet-900/20 rounded-lg p-3">
          <p class="text-xs text-violet-600 dark:text-violet-400 font-medium">Daily Usage</p>
          <p class="text-sm font-bold text-violet-700 dark:text-violet-300"><%= ai_integration.api_calls_today %> / <%= ai_integration.daily_call_limit %></p>
        </div>
        <div class="bg-violet-50 dark:bg-violet-900/20 rounded-lg p-3">
          <p class="text-xs text-violet-600 dark:text-violet-400 font-medium">Status</p>
          <%= render "components/status_badge", status: { "connected" => "active", "syncing" => "warning", "disconnected" => "error" }[ai_integration.connection_status] || ai_integration.connection_status %>
        </div>
      </div>
    <% else %>
      <div class="bg-slate-50 dark:bg-slate-800/50 rounded-lg p-4">
        <p class="text-sm text-slate-600 dark:text-slate-400 mb-2">AI Intelligence is not configured. Enable it to unlock portfolio insights, news sentiment analysis, and fundamental health checks.</p>
        <p class="text-xs text-slate-500">Uncomment the AI Intelligence section in <code class="text-xs bg-slate-200 dark:bg-slate-700 px-1 rounded">db/seeds.rb</code> or create the Integration manually. Supports Anthropic (Claude), OpenAI (GPT), or any compatible endpoint.</p>
      </div>
    <% end %>
  </div>

  <%# Two-column panels %>
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <%# Integrations Panel %>
    <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm p-6">
      <h2 class="text-lg font-bold text-slate-900 dark:text-white mb-4">Data Integrations</h2>
      <% if @integrations.any? %>
        <div class="space-y-3">
          <% @integrations.each do |integration| %>
            <% status_map = { "connected" => "active", "syncing" => "warning", "disconnected" => "error" } %>
            <div class="flex items-center justify-between p-3 rounded-lg bg-slate-50 dark:bg-slate-800/50">
              <div>
                <p class="text-sm font-bold text-slate-900 dark:text-white"><%= integration.provider_name %></p>
                <p class="text-xs text-slate-500"><%= integration.provider_type %></p>
              </div>
              <%= render "components/status_badge", status: status_map[integration.connection_status] || integration.connection_status %>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-slate-400">No integrations configured.</p>
      <% end %>
    </div>

    <%# Recent Logs Panel %>
    <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm p-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-bold text-slate-900 dark:text-white">Recent Logs</h2>
        <%= link_to "View All", admin_logs_path, class: "text-sm text-primary font-medium hover:underline" %>
      </div>
      <% if @recent_logs.any? %>
        <div class="space-y-3">
          <% @recent_logs.each do |log| %>
            <div class="flex items-center justify-between p-3 rounded-lg bg-slate-50 dark:bg-slate-800/50">
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-slate-900 dark:text-white truncate"><%= log.task_name %></p>
                <p class="text-xs text-slate-500"><%= time_ago_in_words(log.created_at) %> ago</p>
              </div>
              <%= render "components/status_badge", status: log.severity %>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-slate-400">No logs recorded yet.</p>
      <% end %>
    </div>
  </div>

  <%# Quick Links %>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <% [
      ["Manage Assets", admin_assets_path, "database", "View and sync all market instruments"],
      ["System Logs",   admin_logs_path,   "receipt_long", "Monitor operations and errors"],
      ["User Management", admin_users_path, "group", "View users and manage integrations"]
    ].each do |label, path, icon, description| %>
      <%= link_to path, class: "bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm p-6 hover:border-primary/50 transition-colors group" do %>
        <div class="flex items-center gap-3 mb-2">
          <span class="material-symbols-outlined text-xl text-primary"><%= icon %></span>
          <h3 class="text-sm font-bold text-slate-900 dark:text-white group-hover:text-primary transition-colors"><%= label %></h3>
        </div>
        <p class="text-xs text-slate-500"><%= description %></p>
      <% end %>
    <% end %>
  </div>
</div>
