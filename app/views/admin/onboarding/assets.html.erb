<% content_for(:admin_page_title, "Setup — Choose Assets") %>

<main class="flex-1 flex flex-col items-center py-10 px-4">
  <div class="w-full max-w-3xl">
    <%# Progress %>
    <div class="mb-10">
      <div class="flex justify-between items-end mb-4">
        <div>
          <span class="text-xs font-bold uppercase tracking-widest text-primary">Admin Setup</span>
          <h2 class="text-slate-500 dark:text-slate-400 text-sm font-medium">Step 2 of 3</h2>
        </div>
        <span class="text-slate-400 text-xs font-semibold italic">66% complete</span>
      </div>
      <div class="h-2 w-full bg-slate-200 dark:bg-slate-800 rounded-full overflow-hidden">
        <div class="h-full bg-primary w-2/3 rounded-full"></div>
      </div>
    </div>

    <%# Title %>
    <div class="mb-8">
      <h1 class="text-3xl font-black text-slate-900 dark:text-white leading-tight mb-3">Choose Assets to Track</h1>
      <p class="text-slate-500 dark:text-slate-400 text-lg">Select the stocks, crypto, and ETFs you want to monitor. You can add more later from Admin > Assets.</p>
    </div>

    <%# Asset Selection Form %>
    <%= form_with url: admin_onboarding_save_assets_path, method: :post, class: "mb-10", data: { controller: "selectable-card" } do |f| %>
      <% @catalog.each do |category_key, assets| %>
        <div class="mb-6">
          <h3 class="text-sm font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400 mb-3">
            <%= Administration::Domain::AssetCatalog.category_label(category_key) %>
          </h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
            <% assets.each do |asset| %>
              <% default_selected = Administration::Domain::AssetCatalog::DEFAULT_SELECTED.include?(asset[:symbol]) %>
              <label class="flex items-center gap-3 p-3 rounded-xl border-2 cursor-pointer transition-all
                            <%= default_selected ? 'border-primary bg-primary/5' : 'border-slate-200 dark:border-slate-800 hover:border-primary/50' %>">
                <input type="checkbox" name="symbols[]" value="<%= asset[:symbol] %>"
                       <%= 'checked' if default_selected %>
                       class="size-4 rounded border-slate-300 text-primary focus:ring-primary">
                <div class="flex-1 min-w-0">
                  <span class="font-bold text-sm text-slate-900 dark:text-white"><%= asset[:symbol] %></span>
                  <span class="text-xs text-slate-500 ml-1 truncate"><%= asset[:name] %></span>
                </div>
                <% if asset[:exchange] %>
                  <span class="text-xs text-slate-400 font-mono"><%= asset[:exchange] %></span>
                <% end %>
              </label>
            <% end %>
          </div>
        </div>
      <% end %>

      <%# Footer Navigation %>
      <div class="flex items-center justify-between pt-6 border-t border-slate-100 dark:border-slate-800">
        <%= link_to admin_onboarding_integrations_path, class: "flex items-center gap-1 text-sm font-medium text-slate-500 hover:text-primary transition-colors" do %>
          <span class="material-symbols-outlined text-sm">arrow_back</span>
          Back
        <% end %>
        <div class="flex items-center gap-4">
          <%= link_to admin_onboarding_complete_path, class: "text-sm font-medium text-slate-500 hover:text-primary transition-colors" do %>
            Skip for now
          <% end %>
          <button type="submit" class="bg-primary hover:bg-primary/90 text-white font-bold py-3 px-8 rounded-xl transition-all shadow-lg shadow-primary/25 flex items-center gap-2">
            Continue
            <span class="material-symbols-outlined text-lg">arrow_forward</span>
          </button>
        </div>
      </div>
    <% end %>
  </div>
</main>
