<% content_for(:admin_page_title, "System Logs") %>

<div class="space-y-6">
  <%# Header %>
  <div class="flex items-start justify-between">
    <div>
      <h1 class="text-2xl font-bold text-slate-900 dark:text-white">System Logs & Operations</h1>
      <p class="text-slate-500 mt-1 flex items-center gap-2">
        <span class="size-2 rounded-full bg-emerald-500 animate-pulse"></span>
        Last refreshed: 2 minutes ago
      </p>
    </div>
    <div class="flex items-center gap-3">
      <%= link_to export_csv_admin_logs_path(severity: params[:severity], module_name: params[:module_name], search: params[:search]),
          class: "inline-flex items-center gap-2 px-4 py-2.5 text-sm font-medium text-slate-700 dark:text-slate-300 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-700 transition-colors" do %>
        <span class="material-symbols-outlined text-lg">download</span>
        Export CSV
      <% end %>
      <%= link_to admin_logs_path,
          class: "inline-flex items-center gap-2 px-4 py-2.5 text-sm font-bold text-white bg-primary rounded-lg hover:bg-primary/90 transition-colors",
          data: { turbo_action: "replace" } do %>
        <span class="material-symbols-outlined text-lg">refresh</span>
        Force Refresh
      <% end %>
    </div>
  </div>

  <%# Filters %>
  <%= render "admin/logs/log_filters" %>

  <%# Logs Table %>
  <%= render "admin/logs/logs_table" %>

  <%# Stats Cards %>
  <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
    <%= render "components/admin_kpi_card", title: "Successful Tasks", value: "98.4%", icon: "check_circle", color: :green, badge: "+0.3% this yesterday" %>
    <%= render "components/admin_kpi_card", title: "Active Alerts", value: "3", icon: "warning", color: :amber, badge: "Requires attention" %>
    <%= render "components/admin_kpi_card", title: "Avg. Run Time", value: "2.4s", icon: "timer", color: :blue %>
    <%= render "components/admin_kpi_card", title: "Log Storage", value: "42GB", icon: "storage", color: :blue %>
  </div>
</div>
