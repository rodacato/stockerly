<%# Relevant News feed — data from @news %>
<section>
  <div class="flex items-center justify-between mb-4">
    <h3 class="text-lg font-bold text-slate-900 dark:text-white">Relevant News</h3>
    <div class="flex gap-2">
      <%= link_to "View All", news_path, class: "rounded-lg bg-primary text-white px-3 py-1.5 text-xs font-bold shadow-sm" %>
    </div>
  </div>
  <div class="space-y-1 bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 p-2 shadow-sm">
    <% @news.each do |article| %>
      <%= render "components/news_card",
        ticker: article.related_ticker,
        sentiment: article.sentiment,
        source: article.source,
        time_ago: time_ago_in_words(article.published_at) + " ago",
        title: article.title %>
    <% end %>
  </div>
  <% if @news.empty? %>
    <p class="text-sm text-slate-500 text-center py-4">No news articles available.</p>
  <% end %>
</section>
