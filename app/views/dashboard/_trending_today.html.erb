<%# Trending Today sidebar — data from @trending %>
<section class="rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 shadow-sm overflow-hidden">
  <div class="flex items-center justify-between border-b border-slate-100 dark:border-slate-800 px-6 py-4">
    <h3 class="text-lg font-bold text-slate-900 dark:text-white">Trending Today</h3>
    <span class="material-symbols-outlined text-slate-400 text-lg">info</span>
  </div>
  <div class="p-4 space-y-1">
    <% @trending.each do |asset| %>
      <% change = asset.change_percent_24h || 0 %>
      <% positive = change >= 0 %>
      <div class="flex items-center justify-between p-2 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors">
        <div class="flex items-center gap-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-full <%= positive ? 'bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400' : 'bg-rose-100 dark:bg-rose-900/30 text-rose-700 dark:text-rose-400' %>">
            <span class="material-symbols-outlined font-bold"><%= positive ? 'trending_up' : 'trending_down' %></span>
          </div>
          <div>
            <p class="text-sm font-bold text-slate-900 dark:text-white"><%= asset.symbol %></p>
            <p class="text-[10px] font-medium text-slate-500 dark:text-slate-400"><%= asset.name %></p>
          </div>
        </div>
        <div class="text-right flex items-center gap-2">
          <p class="text-sm font-bold <%= positive ? 'text-emerald-600 dark:text-emerald-400' : 'text-rose-600 dark:text-rose-400' %>"><%= positive ? '+' : '' %><%= number_to_percentage(change, precision: 1) %></p>
          <button class="text-primary p-1 hover:bg-primary/10 rounded-full transition-colors">
            <span class="material-symbols-outlined text-lg">add_circle</span>
          </button>
        </div>
      </div>
    <% end %>
  </div>
  <div class="p-4 pt-0">
    <%= link_to "Discover More Stocks", market_path, class: "block w-full text-center rounded-lg bg-slate-100 dark:bg-slate-800 py-2.5 text-xs font-bold text-slate-600 dark:text-slate-300 hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors" %>
  </div>
</section>
