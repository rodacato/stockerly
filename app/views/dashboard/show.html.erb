<%# Dashboard — authenticated home page %>
<% if @watchlist_items.blank? && @summary.nil? %>
  <%= render "components/empty_state", icon: "visibility", title: "Your watchlist is empty", description: "Start tracking stocks and crypto by adding them to your watchlist.", cta_text: "Explore Markets", cta_path: market_path %>
<% else %>

<%# Welcome Section %>
<div class="mb-8">
  <h2 class="text-3xl font-extrabold tracking-tight text-slate-900 dark:text-white">Welcome back, <%= current_user.full_name %></h2>
  <% if @summary %>
    <% dg = @summary.day_gain %>
    <p class="mt-1 text-slate-500 dark:text-slate-400">Your portfolio is
      <span class="<%= dg.positive? ? 'text-emerald-600' : 'text-rose-600' %> font-semibold"><%= dg.positive? ? '+' : '' %><%= number_to_percentage(dg.percent, precision: 1) %></span> today.
      Here's what you missed.</p>
  <% else %>
    <p class="mt-1 text-slate-500 dark:text-slate-400">Here's your market overview.</p>
  <% end %>
</div>

<%# Stats Overview — 3 portfolio cards %>
<div class="grid grid-cols-1 gap-4 sm:grid-cols-3 mb-4">
  <% if @summary %>
    <%= render "components/stat_card", title: "Total Balance", value: number_to_currency(@summary.total_value), change: "#{@summary.day_gain.positive? ? '+' : ''}#{number_to_percentage(@summary.day_gain.percent, precision: 1)}", change_positive: @summary.day_gain.positive?, icon: "account_balance_wallet" %>
    <% dg = @summary.day_gain %>
    <%= render "components/stat_card", title: "Day Gain/Loss", value: "#{dg.positive? ? '+' : ''}#{number_to_currency(dg.absolute)}", change: "#{dg.positive? ? '+' : ''}#{number_to_percentage(dg.percent, precision: 1)}", change_positive: dg.positive?, icon: "trending_up" %>
    <%= render "components/stat_card", title: "Buying Power", value: number_to_currency(@summary.buying_power), icon: "savings" %>
  <% else %>
    <%= render "components/stat_card", title: "Total Balance", value: "$0.00", icon: "account_balance_wallet" %>
    <%= render "components/stat_card", title: "Day Gain/Loss", value: "$0.00", icon: "trending_up" %>
    <%= render "components/stat_card", title: "Buying Power", value: "$0.00", icon: "savings" %>
  <% end %>
</div>

<%# Sentiment & Fear/Greed — 3 cards %>
<div class="grid grid-cols-1 gap-4 sm:grid-cols-3 mb-8">
  <%# Market Sentiment — watchlist-based %>
  <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 p-5 shadow-sm">
    <div class="flex items-center justify-between mb-3">
      <div class="flex items-center gap-2 text-slate-500 dark:text-slate-400">
        <span class="material-symbols-outlined text-lg">monitoring</span>
        <p class="text-sm font-semibold tracking-tight uppercase">Watchlist Sentiment</p>
      </div>
    </div>
    <% sentiment_value = @sentiment[:value] %>
    <div class="flex flex-col items-center py-1 mb-4">
      <span class="text-4xl font-bold text-slate-900 dark:text-white"><%= sentiment_value %></span>
      <span class="text-xs font-bold tracking-wide uppercase text-slate-500 dark:text-slate-400 mt-1"><%= @sentiment[:label] %></span>
    </div>
    <div class="h-2 w-full bg-slate-100 dark:bg-slate-800 rounded-full overflow-hidden flex">
      <div class="h-full bg-emerald-500" style="width: <%= sentiment_value %>%"></div>
      <div class="h-full bg-amber-400" style="width: <%= [100 - sentiment_value, 20].min %>%"></div>
      <div class="h-full bg-rose-500" style="width: <%= [100 - sentiment_value - 20, 0].max %>%"></div>
    </div>
    <p class="mt-2 text-xs font-medium text-slate-400"><%= sentiment_value %>% — Based on your watchlist</p>
  </div>

  <%# Crypto Fear & Greed %>
  <%= render "dashboard/fear_greed_card", reading: @fear_greed[:crypto], label: "Crypto", history: @fear_greed[:crypto_history] %>

  <%# Stocks Fear & Greed %>
  <%= render "dashboard/fear_greed_card", reading: @fear_greed[:stocks], label: "Stocks", history: @fear_greed[:stocks_history] %>
</div>

<%# Dashboard Grid — 8 + 4 columns %>
<div class="grid grid-cols-1 gap-8 lg:grid-cols-12">
  <%# Main Content Column %>
  <div class="lg:col-span-8 space-y-8">
    <%= render "dashboard/watchlist_table" %>
    <%= turbo_frame_tag "dashboard_news_feed", src: dashboard_news_feed_path, loading: "lazy" do %>
      <%= render "components/skeleton", type: "card", count: 3 %>
    <% end %>
  </div>

  <%# Sidebar Column %>
  <div class="lg:col-span-4 space-y-8">
    <%= turbo_frame_tag "dashboard_trending", src: dashboard_trending_path, loading: "lazy" do %>
      <%= render "components/skeleton", type: "card", count: 1 %>
    <% end %>
    <%= render "dashboard/weekly_insight" %>
    <%= render "dashboard/market_status" %>
  </div>
</div>
<% end %>
