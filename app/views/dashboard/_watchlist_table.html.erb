<%# Watchlist Performance table — data from @watchlist_items %>
<section class="rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 overflow-hidden shadow-sm">
  <div class="flex items-center justify-between border-b border-slate-100 dark:border-slate-800 px-6 py-4">
    <h3 class="text-lg font-bold text-slate-900 dark:text-white">Watchlist Performance</h3>
    <%= link_to "View All", market_path, class: "text-sm font-semibold text-primary hover:underline" %>
  </div>
  <% if @watchlist_items.present? %>
    <div class="overflow-x-auto">
      <table class="w-full text-left">
        <thead class="bg-slate-50 dark:bg-slate-800/50 text-xs uppercase tracking-wider text-slate-500">
          <tr>
            <th class="px-6 py-3 font-semibold">Ticker</th>
            <th class="px-6 py-3 font-semibold text-right">Price</th>
            <th class="px-6 py-3 font-semibold text-right">Change %</th>
            <th class="px-6 py-3 font-semibold text-center">Trend</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
          <% @watchlist_items.each do |item| %>
            <% asset = item.asset %>
            <% change = asset.change_percent_24h || 0 %>
            <% positive = change >= 0 %>
            <%= turbo_stream_from "asset_#{asset.id}" %>
            <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/30 transition-colors">
              <td class="px-6 py-4">
                <div class="flex items-center gap-3">
                  <%= render "components/asset_badge", asset: asset, size: "sm", market_open: market_open_for(asset) %>
                  <div>
                    <p class="text-sm font-bold text-slate-900 dark:text-white"><%= asset.name %></p>
                    <p class="text-xs text-slate-500"><%= asset.sector %></p>
                  </div>
                </div>
              </td>
              <td id="asset_price_<%= asset.id %>" class="px-6 py-4 text-right"
                  data-controller="price-flash" data-price-flash-value="<%= asset.current_price %>">
                <span class="text-sm font-medium text-slate-900 dark:text-white"><%= number_to_currency(asset.current_price) %></span>
                <div class="mt-0.5"><%= render "components/data_status", asset: asset, market_open: market_open_for(asset) %></div>
              </td>
              <td class="px-6 py-4 text-right">
                <span class="inline-flex items-center rounded-lg px-2.5 py-1 text-xs font-bold <%= positive ? 'bg-emerald-50 dark:bg-emerald-900/30 text-emerald-600 dark:text-emerald-400' : 'bg-rose-50 dark:bg-rose-900/30 text-rose-600 dark:text-rose-400' %>">
                  <%= positive ? '+' : '' %><%= number_to_percentage(change, precision: 2) %>
                </span>
              </td>
              <td class="px-6 py-4">
                <div class="mx-auto flex justify-center">
                  <% real_heights = sparkline_heights(asset) %>
                  <%= render "components/sparkline", direction: positive ? :up : :down, heights: real_heights %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="px-6 py-8 text-center text-sm text-slate-500">
      No assets in your watchlist yet. <%= link_to "Explore Markets", market_path, class: "text-primary font-semibold hover:underline" %>
    </div>
  <% end %>
</section>
