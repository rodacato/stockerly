<%# Dividend payment history — last 12 records from @dividends %>
<% if @dividends.present? %>
  <%# Annual summary %>
  <%
    annual_totals = @dividends.group_by { |d| d.ex_date.year }.transform_values do |divs|
      divs.sum { |d| d.amount_per_share.to_f }
    end
  %>

  <div class="mt-8">
    <h4 class="text-sm font-bold text-slate-900 dark:text-white mb-4">Dividend History</h4>

    <% if annual_totals.size >= 2 %>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6">
        <% annual_totals.first(4).each do |year, total| %>
          <div class="bg-slate-50 dark:bg-slate-800/50 rounded-lg p-3 text-center">
            <p class="text-[10px] font-bold uppercase text-slate-400"><%= year %></p>
            <span class="text-lg font-black text-slate-900 dark:text-white"><%= number_to_currency(total) %></span>
            <p class="text-[10px] text-slate-400">per share</p>
          </div>
        <% end %>
      </div>
    <% end %>

    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-slate-200 dark:border-slate-800">
            <th class="text-left py-3 px-4 text-xs font-bold uppercase tracking-wider text-slate-400">Ex-Date</th>
            <th class="text-left py-3 px-4 text-xs font-bold uppercase tracking-wider text-slate-400">Pay Date</th>
            <th class="text-right py-3 px-4 text-xs font-bold uppercase tracking-wider text-slate-400">Amount/Share</th>
          </tr>
        </thead>
        <tbody>
          <% @dividends.each do |div| %>
            <tr class="border-b border-slate-100 dark:border-slate-800/50 hover:bg-slate-50 dark:hover:bg-slate-800/30">
              <td class="py-3 px-4 text-slate-900 dark:text-white font-medium">
                <%= div.ex_date.strftime("%b %d, %Y") %>
              </td>
              <td class="py-3 px-4 text-slate-600 dark:text-slate-300">
                <%= div.pay_date&.strftime("%b %d, %Y") || "—" %>
              </td>
              <td class="py-3 px-4 text-right font-bold text-emerald-600 dark:text-emerald-400">
                <%= number_to_currency(div.amount_per_share) %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% end %>
