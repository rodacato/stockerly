<%# Summary tab: adaptive metrics based on asset type %>
<% if @has_fundamentals %>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 mb-8">
    <% summary_metrics_for(@asset).each do |key| %>
      <% defn = MarketData::Domain::MetricDefinitions.find(key) rescue nil %>
      <% next unless defn %>
      <% value = resolve_metric_value(@presenter, key) %>
      <%= render "market/metric_card", definition: defn, value: value %>
    <% end %>
  </div>

  <%= render "market/analyst_target" %>
<% else %>
  <div class="flex flex-col items-center justify-center py-16 text-center">
    <span class="material-symbols-outlined text-5xl text-slate-300 dark:text-slate-600 mb-4">analytics</span>
    <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-2">No fundamental data available</h3>
    <p class="text-sm text-slate-500 dark:text-slate-400 max-w-md">
      Fundamental data is not yet available for this asset. Data syncs daily — check back soon.
    </p>
  </div>
<% end %>
