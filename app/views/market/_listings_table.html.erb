<%# Market Listings table with real data from @assets %>
<section class="rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 overflow-hidden shadow-sm">
  <div class="flex items-center justify-between border-b border-slate-100 dark:border-slate-800 px-6 py-4">
    <h3 class="text-lg font-bold text-slate-900 dark:text-white">Market Listings</h3>
    <p class="text-sm text-slate-500 dark:text-slate-400"><span class="font-bold text-slate-900 dark:text-white"><%= @pagy.count %></span> assets found</p>
  </div>
  <div class="overflow-x-auto">
    <table class="w-full text-left">
      <thead class="bg-slate-50 dark:bg-slate-800/50 text-xs uppercase tracking-wider text-slate-500">
        <tr>
          <th class="px-6 py-3 font-semibold">Asset / Ticker</th>
          <th class="px-6 py-3 font-semibold text-right">Price</th>
          <th class="px-6 py-3 font-semibold text-right">Change (24h)</th>
          <th class="px-6 py-3 font-semibold text-center">Trend Strength</th>
          <th class="px-6 py-3 font-semibold text-center">7D Sparkline</th>
          <th class="px-6 py-3 font-semibold text-center">Action</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
        <% @assets.each do |asset| %>
          <% change = asset.change_percent_24h || 0 %>
          <% positive = change >= 0 %>
          <% score = asset.latest_trend_score %>
          <% strength = score&.score || 0 %>
          <% strength_label = case strength
               when 80..100 then strength >= 90 ? "Parabolic" : "Strong"
               when 50..79  then "Moderate"
               when 25..49  then "Weakening"
               else "Weak"
             end %>
          <%= turbo_stream_from "asset_#{asset.id}" %>
          <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/30 transition-colors cursor-pointer"
              data-controller="row-link" data-row-link-url-value="<%= market_asset_path(asset.symbol) %>"
              data-action="click->row-link#visit">
            <td class="px-6 py-4">
              <%= link_to market_asset_path(asset.symbol), class: "flex items-center gap-3 group" do %>
                <%= render "components/asset_badge", asset: asset, size: "sm", market_open: market_open_for(asset) %>
                <div>
                  <p class="text-sm font-bold text-slate-900 dark:text-white group-hover:text-primary transition-colors">
                    <% if asset.exchange.present? %>
                      <span class="text-slate-400 dark:text-slate-500 font-medium"><%= asset.exchange %></span>
                      <span class="text-slate-300 dark:text-slate-600 font-normal mx-0.5">:</span>
                    <% end %>
                    <%= asset.symbol %>
                  </p>
                  <p class="text-xs text-slate-500"><%= asset.name %></p>
                </div>
              <% end %>
            </td>
            <td id="asset_price_<%= asset.id %>" class="px-6 py-4 text-right"
                data-controller="price-flash" data-price-flash-value="<%= asset.current_price %>">
              <span class="text-sm font-medium text-slate-900 dark:text-white"><%= number_to_currency(asset.current_price) %></span>
              <div class="mt-0.5"><%= render "components/data_status", asset: asset, market_open: market_open_for(asset) %></div>
            </td>
            <td class="px-6 py-4 text-right">
              <span class="inline-flex items-center rounded-lg px-2.5 py-1 text-xs font-bold <%= positive ? 'bg-emerald-50 dark:bg-emerald-900/30 text-emerald-600 dark:text-emerald-400' : 'bg-rose-50 dark:bg-rose-900/30 text-rose-600 dark:text-rose-400' %>">
                <%= positive ? '+' : '' %><%= number_with_precision(change, precision: 2) %>%
              </span>
            </td>
            <td class="px-6 py-4">
              <div class="flex flex-col items-center gap-1">
                <div class="w-full max-w-[80px] h-1.5 bg-slate-100 dark:bg-slate-800 rounded-full overflow-hidden">
                  <% bar_color = if strength >= 80
                       'bg-emerald-500'
                     elsif strength >= 50
                       'bg-amber-400'
                     else
                       'bg-rose-400'
                     end %>
                  <div class="h-full rounded-full <%= bar_color %>" style="width: <%= strength %>%"></div>
                </div>
                <span class="text-[10px] font-medium text-slate-500"><%= strength_label %> (<%= strength %>%)</span>
              </div>
            </td>
            <td class="px-6 py-4">
              <div class="flex justify-center">
                <% real_heights = sparkline_heights(asset) %>
                <%= render "components/sparkline", direction: positive ? :up : :down, heights: real_heights %>
              </div>
            </td>
            <td class="px-6 py-4">
              <div class="flex items-center justify-center gap-2">
                <%= turbo_frame_tag "watchlist_button_#{asset.id}" do %>
                  <% if @watchlisted_asset_ids.include?(asset.id) %>
                    <span class="inline-flex items-center gap-1 text-emerald-500 text-xs font-medium">
                      <span class="material-symbols-outlined text-lg">check_circle</span>
                    </span>
                  <% else %>
                    <%= button_to watchlist_items_path, params: { asset_id: asset.id }, class: "p-2 rounded-lg text-primary hover:bg-primary/10 transition-colors" do %>
                      <span class="material-symbols-outlined text-lg">add_circle</span>
                    <% end %>
                  <% end %>
                <% end %>
                <span class="material-symbols-outlined text-slate-300 dark:text-slate-600 text-lg">chevron_right</span>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <%# Pagination %>
  <div class="border-t border-slate-100 dark:border-slate-800 px-6 py-4">
    <%== pagy_nav(@pagy) %>
  </div>
</section>
