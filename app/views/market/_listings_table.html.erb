<%# Market Listings table with hardcoded data %>
<% listings = [
  { ticker: "AAPL", name: "Apple Inc.", sector: "Technology", price: "$185.92", change: "+1.45%", positive: true, strength: 88, strength_label: "Strong", direction: :up },
  { ticker: "TSLA", name: "Tesla, Inc.", sector: "Automotive", price: "$175.22", change: "-2.10%", positive: false, strength: 42, strength_label: "Weakening", direction: :down },
  { ticker: "NVDA", name: "NVIDIA Corp.", sector: "Semiconductors", price: "$894.52", change: "+3.82%", positive: true, strength: 96, strength_label: "Parabolic", direction: :up },
  { ticker: "MSFT", name: "Microsoft Corp.", sector: "Software", price: "$415.10", change: "+0.32%", positive: true, strength: 72, strength_label: "Moderate", direction: :up },
  { ticker: "AMZN", name: "Amazon.com Inc.", sector: "E-Commerce", price: "$178.25", change: "+0.95%", positive: true, strength: 67, strength_label: "Moderate", direction: :up },
  { ticker: "GOOGL", name: "Alphabet Inc.", sector: "Technology", price: "$141.80", change: "-0.15%", positive: false, strength: 55, strength_label: "Moderate", direction: :down },
  { ticker: "META", name: "Meta Platforms", sector: "Technology", price: "$505.75", change: "+2.18%", positive: true, strength: 81, strength_label: "Strong", direction: :up },
  { ticker: "JPM", name: "JPMorgan Chase", sector: "Finance", price: "$198.40", change: "+0.44%", positive: true, strength: 63, strength_label: "Moderate", direction: :up },
  { ticker: "JNJ", name: "Johnson & Johnson", sector: "Healthcare", price: "$156.80", change: "-0.65%", positive: false, strength: 35, strength_label: "Weak", direction: :down },
  { ticker: "VIX", name: "Volatility Index", sector: "Index", price: "14.33", change: "-1.22%", positive: false, strength: 25, strength_label: "Sideways", direction: :down }
] %>

<section class="rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 overflow-hidden shadow-sm">
  <div class="flex items-center justify-between border-b border-slate-100 dark:border-slate-800 px-6 py-4">
    <h3 class="text-lg font-bold text-slate-900 dark:text-white">Market Listings</h3>
    <p class="text-sm text-slate-500 dark:text-slate-400"><span class="font-bold text-slate-900 dark:text-white">4,821</span> assets found</p>
  </div>
  <div class="overflow-x-auto">
    <table class="w-full text-left">
      <thead class="bg-slate-50 dark:bg-slate-800/50 text-xs uppercase tracking-wider text-slate-500">
        <tr>
          <th class="px-6 py-3 font-semibold">Asset / Ticker</th>
          <th class="px-6 py-3 font-semibold text-right">Price</th>
          <th class="px-6 py-3 font-semibold text-right">Change (24h)</th>
          <th class="px-6 py-3 font-semibold text-center">Trend Strength</th>
          <th class="px-6 py-3 font-semibold text-center">7D Sparkline</th>
          <th class="px-6 py-3 font-semibold text-center">Action</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
        <% listings.each do |asset| %>
          <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/30 transition-colors">
            <td class="px-6 py-4">
              <div class="flex items-center gap-3">
                <div class="flex h-8 w-8 items-center justify-center rounded bg-slate-100 dark:bg-slate-800 font-bold text-[10px] text-slate-700 dark:text-slate-300">
                  <%= asset[:ticker] %>
                </div>
                <div>
                  <p class="text-sm font-bold text-slate-900 dark:text-white"><%= asset[:name] %></p>
                  <p class="text-xs text-slate-500"><%= asset[:sector] %></p>
                </div>
              </div>
            </td>
            <td class="px-6 py-4 text-right text-sm font-medium text-slate-900 dark:text-white"><%= asset[:price] %></td>
            <td class="px-6 py-4 text-right">
              <span class="inline-flex items-center rounded-lg px-2.5 py-1 text-xs font-bold <%= asset[:positive] ? 'bg-emerald-50 dark:bg-emerald-900/30 text-emerald-600 dark:text-emerald-400' : 'bg-rose-50 dark:bg-rose-900/30 text-rose-600 dark:text-rose-400' %>">
                <%= asset[:change] %>
              </span>
            </td>
            <td class="px-6 py-4">
              <div class="flex flex-col items-center gap-1">
                <div class="w-full max-w-[80px] h-1.5 bg-slate-100 dark:bg-slate-800 rounded-full overflow-hidden">
                  <% bar_color = if asset[:strength] >= 80
                       'bg-emerald-500'
                     elsif asset[:strength] >= 50
                       'bg-amber-400'
                     else
                       'bg-rose-400'
                     end %>
                  <div class="h-full rounded-full <%= bar_color %>" style="width: <%= asset[:strength] %>%"></div>
                </div>
                <span class="text-[10px] font-medium text-slate-500"><%= asset[:strength_label] %> (<%= asset[:strength] %>%)</span>
              </div>
            </td>
            <td class="px-6 py-4">
              <div class="flex justify-center">
                <%= render "components/sparkline", direction: asset[:direction] %>
              </div>
            </td>
            <td class="px-6 py-4 text-center">
              <button class="p-2 rounded-lg text-primary hover:bg-primary/10 transition-colors">
                <span class="material-symbols-outlined text-lg">add_circle</span>
              </button>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <%# Pagination %>
  <div class="border-t border-slate-100 dark:border-slate-800 px-6 py-4">
    <%= render "components/pagination", current_page: 1, total_pages: 482, total_count: 4821, per_page: 10 %>
  </div>
</section>
