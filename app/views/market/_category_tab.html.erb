<%# Generic category tab: renders metric cards for a given MarketData::MetricDefinitions category %>
<% if @has_fundamentals %>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 mb-12">
    <% MarketData::MetricDefinitions.by_category(category).each do |defn| %>
      <% value = resolve_metric_value(@presenter, defn.key) %>
      <%= render "market/metric_card", definition: defn, value: value %>
    <% end %>
  </div>
<% else %>
  <div class="flex flex-col items-center justify-center py-16 text-center">
    <span class="material-symbols-outlined text-5xl text-slate-300 dark:text-slate-600 mb-4">analytics</span>
    <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-2">No data available</h3>
    <p class="text-sm text-slate-500 dark:text-slate-400 max-w-md">
      Fundamental data has not been synced for this asset yet.
    </p>
  </div>
<% end %>
