<%# Generic category tab: renders metric cards for a given MarketData::Domain::MetricDefinitions category %>
<% if @has_fundamentals %>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 mb-12">
    <% MarketData::Domain::MetricDefinitions.by_category(category).each do |defn| %>
      <% value = resolve_metric_value(@presenter, defn.key) %>
      <%= render "market/metric_card", definition: defn, value: value %>
    <% end %>
  </div>
<% else %>
  <%= render "components/empty_state", icon: "analytics", title: "No data available", description: "Fundamental data has not been synced for this asset yet." %>
<% end %>
