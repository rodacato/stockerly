<%# Active Alert Rules table with hardcoded data %>
<% rules = [
  { ticker: "AAPL", condition: "Price Crosses Above", target: "$195.00", status: :active },
  { ticker: "TSLA", condition: "RSI Oversold", target: "< 30", status: :paused },
  { ticker: "BTC/USD", condition: "Day Change %", target: "> 5%", status: :active },
  { ticker: "NVDA", condition: "Price Crosses Above", target: "$900.00", status: :active },
  { ticker: "MSFT", condition: "Price Crosses Below", target: "$400.00", status: :paused },
  { ticker: "AMZN", condition: "% Day Change >", target: "3%", status: :active }
] %>

<section class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden">
  <div class="p-6 border-b border-slate-200 dark:border-slate-800 flex justify-between items-center">
    <h3 class="font-bold text-lg text-slate-900 dark:text-white">Active Alert Rules</h3>
    <div class="flex gap-2">
      <button class="text-xs font-bold text-primary px-3 py-1 rounded hover:bg-primary/5 transition-colors uppercase">Pause All</button>
      <button class="text-xs font-bold text-red-500 px-3 py-1 rounded hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors uppercase">Clear All</button>
    </div>
  </div>
  <div class="overflow-x-auto">
    <table class="w-full text-left border-collapse">
      <thead>
        <tr class="bg-slate-50 dark:bg-slate-800/50 text-slate-500 text-[10px] uppercase font-bold tracking-widest">
          <th class="px-6 py-3">Symbol</th>
          <th class="px-6 py-3">Condition</th>
          <th class="px-6 py-3">Target</th>
          <th class="px-6 py-3 text-center">Status</th>
          <th class="px-6 py-3 text-right">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
        <% rules.each do |rule| %>
          <% is_active = rule[:status] == :active %>
          <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/30 transition-colors group">
            <td class="px-6 py-4 font-black text-slate-900 dark:text-white"><%= rule[:ticker] %></td>
            <td class="px-6 py-4 text-sm text-slate-600 dark:text-slate-400"><%= rule[:condition] %></td>
            <td class="px-6 py-4 text-sm font-semibold text-slate-900 dark:text-white"><%= rule[:target] %></td>
            <td class="px-6 py-4">
              <div class="flex justify-center">
                <span class="px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-tighter <%= is_active ? 'bg-emerald-100 text-emerald-700 dark:bg-emerald-500/20 dark:text-emerald-400' : 'bg-amber-100 text-amber-700 dark:bg-amber-500/20 dark:text-amber-400' %>">
                  <%= is_active ? 'Active' : 'Paused' %>
                </span>
              </div>
            </td>
            <td class="px-6 py-4 text-right">
              <div class="flex justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                <button class="p-1.5 hover:bg-primary/10 rounded text-primary transition-colors">
                  <span class="material-symbols-outlined text-lg"><%= is_active ? 'edit' : 'play_arrow' %></span>
                </button>
                <button class="p-1.5 hover:bg-red-50 dark:hover:bg-red-900/20 rounded text-red-500 transition-colors">
                  <span class="material-symbols-outlined text-lg">delete</span>
                </button>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>
