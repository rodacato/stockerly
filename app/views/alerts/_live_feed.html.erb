<%# Live Alert Feed — data from @events %>
<section class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm flex flex-col max-h-[700px]">
  <div class="p-6 border-b border-slate-200 dark:border-slate-800 flex justify-between items-center bg-primary text-white rounded-t-xl">
    <h3 class="font-bold text-lg flex items-center gap-2">
      <span class="material-symbols-outlined">bolt</span>
      Live Alert Feed
    </h3>
    <span class="bg-white/20 px-2 py-0.5 rounded text-[10px] font-bold animate-pulse">LIVE</span>
  </div>
  <div class="flex-grow overflow-y-auto p-4 space-y-3">
    <% if @events.present? %>
      <% @events.each do |event| %>
        <% is_triggered = event.triggered? %>
        <% border_color = is_triggered ? 'border-l-emerald-500' : 'border-l-slate-300 dark:border-l-slate-600' %>
        <div class="p-4 rounded-lg border-l-4 <%= border_color %> relative transition-all hover:translate-x-1 <%= is_triggered ? 'bg-slate-50 dark:bg-slate-800' : 'bg-white dark:bg-slate-900 border border-slate-100 dark:border-slate-800 opacity-70' %>">
          <span class="absolute top-2 right-4 text-[10px] text-slate-400 font-medium"><%= time_ago_in_words(event.triggered_at) %> ago</span>
          <div class="flex items-center gap-2 mb-1">
            <span class="font-black text-slate-900 dark:text-white"><%= event.asset_symbol %></span>
            <% if is_triggered %>
              <span class="text-[10px] font-bold px-1.5 py-0.5 rounded uppercase bg-emerald-100 text-emerald-700 dark:bg-emerald-500/20 dark:text-emerald-400">Triggered</span>
            <% else %>
              <span class="text-[10px] bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-400 px-1.5 py-0.5 rounded font-bold uppercase">Settled</span>
            <% end %>
          </div>
          <p class="text-sm text-slate-600 dark:text-slate-400"><%= event.message %></p>
        </div>
      <% end %>
    <% else %>
      <p class="text-sm text-slate-500 text-center py-8">No recent alert events.</p>
    <% end %>
  </div>
</section>
