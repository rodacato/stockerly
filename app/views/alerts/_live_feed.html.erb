<%# Live Alert Feed with hardcoded events %>
<% events = [
  { ticker: "MSFT", message: "Price crossed above resistance at <strong>$420.50</strong>", time_ago: "2 mins ago", severity: :triggered, direction: :up },
  { ticker: "AMZN", message: "Price fell below target of <strong>$175.00</strong>", time_ago: "15 mins ago", severity: :triggered, direction: :down },
  { ticker: "NVDA", message: "24h volume spiked by <strong>12.5%</strong>", time_ago: "1 hour ago", severity: :settled, direction: :up },
  { ticker: "META", message: "Golden cross pattern detected on 4H chart.", time_ago: "2 hours ago", severity: :settled, direction: :up },
  { ticker: "TSLA", message: "RSI approaching oversold territory at <strong>32.1</strong>", time_ago: "3 hours ago", severity: :settled, direction: :down },
  { ticker: "AAPL", message: "Price crossed above <strong>$190.00</strong> resistance", time_ago: "4 hours ago", severity: :settled, direction: :up },
  { ticker: "JPM", message: "Unusual options activity detected (call sweep)", time_ago: "5 hours ago", severity: :settled, direction: :up },
  { ticker: "GOOGL", message: "Breakout above 50-day SMA at <strong>$142.50</strong>", time_ago: "6 hours ago", severity: :settled, direction: :up }
] %>

<section class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm flex flex-col max-h-[700px]">
  <div class="p-6 border-b border-slate-200 dark:border-slate-800 flex justify-between items-center bg-primary text-white rounded-t-xl">
    <h3 class="font-bold text-lg flex items-center gap-2">
      <span class="material-symbols-outlined">bolt</span>
      Live Alert Feed
    </h3>
    <span class="bg-white/20 px-2 py-0.5 rounded text-[10px] font-bold animate-pulse">LIVE</span>
  </div>
  <div class="flex-grow overflow-y-auto p-4 space-y-3">
    <% events.each do |event| %>
      <% is_triggered = event[:severity] == :triggered %>
      <% border_color = if is_triggered
           event[:direction] == :up ? 'border-l-emerald-500' : 'border-l-rose-500'
         else
           'border-l-slate-300 dark:border-l-slate-600'
         end %>
      <div class="p-4 rounded-lg border-l-4 <%= border_color %> relative transition-all hover:translate-x-1 <%= is_triggered ? 'bg-slate-50 dark:bg-slate-800' : 'bg-white dark:bg-slate-900 border border-slate-100 dark:border-slate-800 opacity-70' %>">
        <span class="absolute top-2 right-4 text-[10px] text-slate-400 font-medium"><%= event[:time_ago] %></span>
        <div class="flex items-center gap-2 mb-1">
          <span class="font-black text-slate-900 dark:text-white"><%= event[:ticker] %></span>
          <% if is_triggered %>
            <span class="text-[10px] font-bold px-1.5 py-0.5 rounded uppercase <%= event[:direction] == :up ? 'bg-emerald-100 text-emerald-700 dark:bg-emerald-500/20 dark:text-emerald-400' : 'bg-rose-100 text-rose-700 dark:bg-rose-500/20 dark:text-rose-400' %>">Triggered</span>
          <% else %>
            <span class="text-[10px] bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-400 px-1.5 py-0.5 rounded font-bold uppercase">Settled</span>
          <% end %>
        </div>
        <p class="text-sm text-slate-600 dark:text-slate-400"><%= raw event[:message] %></p>
      </div>
    <% end %>
  </div>
  <div class="p-4 border-t border-slate-200 dark:border-slate-800">
    <button class="w-full text-center text-primary text-sm font-bold hover:underline">View History (24h)</button>
  </div>
</section>
