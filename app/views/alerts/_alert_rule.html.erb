<%# Single alert rule row for Turbo Stream operations %>
<% is_active = rule.active? %>
<%= tag.tr id: dom_id(rule), class: "hover:bg-slate-50 dark:hover:bg-slate-800/30 transition-colors group" do %>
  <td class="px-6 py-4 font-black text-slate-900 dark:text-white"><%= rule.asset_symbol %></td>
  <td class="px-6 py-4 text-sm text-slate-600 dark:text-slate-400"><%= rule.condition.humanize %></td>
  <td class="px-6 py-4 text-sm font-semibold text-slate-900 dark:text-white"><%= rule.threshold_value %></td>
  <td class="px-6 py-4">
    <div class="flex justify-center">
      <span class="px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-tighter <%= is_active ? 'bg-emerald-100 text-emerald-700 dark:bg-emerald-500/20 dark:text-emerald-400' : 'bg-amber-100 text-amber-700 dark:bg-amber-500/20 dark:text-amber-400' %>">
        <%= is_active ? 'Active' : 'Paused' %>
      </span>
    </div>
  </td>
  <td class="px-6 py-4 text-right">
    <div class="flex justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
      <%= button_to toggle_alert_path(rule), method: :patch, class: "p-1.5 hover:bg-primary/10 rounded text-primary transition-colors", data: { turbo_method: :patch } do %>
        <span class="material-symbols-outlined text-lg"><%= is_active ? 'pause' : 'play_arrow' %></span>
      <% end %>
      <%= button_to alert_path(rule), method: :delete, class: "p-1.5 hover:bg-red-50 dark:hover:bg-red-900/20 rounded text-red-500 transition-colors", data: { turbo_method: :delete } do %>
        <span class="material-symbols-outlined text-lg">delete</span>
      <% end %>
    </div>
  </td>
<% end %>
