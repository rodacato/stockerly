<%# Delivery Preferences with toggle switches — data from @preference %>
<section class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm p-6">
  <h4 class="font-bold text-sm mb-4 uppercase tracking-wider text-slate-500">Delivery Preferences</h4>
  <div class="space-y-4">
    <% prefs = [
      { icon: "desktop_windows", label: "Browser Push", checked: @preference&.browser_push },
      { icon: "mail", label: "Email Digest", checked: @preference&.email_digest },
      { icon: "sms", label: "SMS Notifications", checked: @preference&.sms_notifications }
    ] %>
    <% prefs.each do |pref| %>
      <div class="flex items-center justify-between" data-controller="toggle">
        <div class="flex items-center gap-3">
          <span class="material-symbols-outlined text-primary"><%= pref[:icon] %></span>
          <span class="text-sm font-medium text-slate-700 dark:text-slate-300"><%= pref[:label] %></span>
        </div>
        <button type="button" data-action="click->toggle#toggle"
                class="relative inline-flex h-6 w-11 shrink-0 cursor-pointer rounded-full border-2 border-transparent transition-colors duration-200 ease-in-out focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2">
          <span data-toggle-target="track" class="pointer-events-none inline-block h-5 w-11 rounded-full transition-colors duration-200 ease-in-out <%= pref[:checked] ? 'bg-primary' : 'bg-slate-200 dark:bg-slate-700' %>"></span>
          <span data-toggle-target="knob" class="pointer-events-none absolute left-0 inline-block h-5 w-5 rounded-full bg-white shadow ring-0 transition-transform duration-200 ease-in-out <%= pref[:checked] ? 'translate-x-5' : 'translate-x-0' %>"></span>
        </button>
      </div>
    <% end %>
  </div>
</section>
