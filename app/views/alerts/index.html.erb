<%# Alerts — manage alert rules and view live feed %>

<%# Header with stat badges %>
<div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-8 gap-6">
  <div class="space-y-1">
    <h1 class="text-3xl font-black text-slate-900 dark:text-white tracking-tight">Trend Alerts</h1>
    <p class="text-slate-500 dark:text-slate-400">Monitor and manage your real-time market notifications.</p>
  </div>
  <div class="flex gap-4 w-full md:w-auto">
    <div class="bg-white dark:bg-slate-900 p-4 rounded-xl border border-slate-200 dark:border-slate-800 flex flex-col min-w-[160px] shadow-sm">
      <span class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Triggered Today</span>
      <div class="flex items-center gap-2">
        <span class="text-2xl font-bold text-slate-900 dark:text-white">14</span>
        <span class="text-xs font-medium text-emerald-500 flex items-center bg-emerald-50 dark:bg-emerald-500/10 px-1.5 py-0.5 rounded">+5%</span>
      </div>
    </div>
    <div class="bg-white dark:bg-slate-900 p-4 rounded-xl border border-slate-200 dark:border-slate-800 flex flex-col min-w-[160px] shadow-sm">
      <span class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Active Rules</span>
      <div class="flex items-center gap-2">
        <span class="text-2xl font-bold text-slate-900 dark:text-white">28</span>
        <span class="text-xs font-medium text-slate-400 bg-slate-50 dark:bg-slate-800 px-1.5 py-0.5 rounded">Stable</span>
      </div>
    </div>
  </div>
</div>

<%# Main Grid — 8 + 4 %>
<div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
  <%# Left Column: Create + Rules %>
  <div class="lg:col-span-8 space-y-6">
    <%= render "alerts/create_form" %>
    <%= render "alerts/rules_table" %>
  </div>

  <%# Right Column: Live Feed + Delivery Preferences %>
  <div class="lg:col-span-4 space-y-6">
    <%= render "alerts/live_feed" %>
    <%= render "alerts/delivery_preferences" %>
  </div>
</div>
