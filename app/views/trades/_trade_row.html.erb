<%# Single trade row — used by index and Turbo Stream prepend %>
<% is_buy = trade.buy? %>
<tr id="<%= dom_id(trade) %>" class="hover:bg-slate-50 dark:hover:bg-slate-800/30 transition-colors">
  <td class="px-6 py-4 text-sm text-slate-500"><%= trade.executed_at.strftime("%b %d, %Y %H:%M") %></td>
  <td class="px-6 py-4">
    <div class="flex items-center gap-2">
      <%= render "components/asset_badge", asset: trade.asset, size: "sm" %>
      <span class="text-sm font-bold text-slate-900 dark:text-white"><%= trade.asset.symbol %></span>
    </div>
  </td>
  <td class="px-6 py-4 text-center">
    <span class="px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-tighter <%= is_buy ? 'bg-emerald-100 text-emerald-700 dark:bg-emerald-500/20 dark:text-emerald-400' : 'bg-rose-100 text-rose-700 dark:bg-rose-500/20 dark:text-rose-400' %>">
      <%= trade.side %>
    </span>
  </td>
  <td class="px-6 py-4 text-right text-sm font-medium text-slate-900 dark:text-white"><%= trade.shares %></td>
  <td class="px-6 py-4 text-right text-sm text-slate-500"><%= number_to_currency(trade.price_per_share) %></td>
  <td class="px-6 py-4 text-right text-sm font-bold text-slate-900 dark:text-white"><%= number_to_currency(trade.total_amount) %></td>
  <td class="px-6 py-4 text-right text-sm text-slate-400"><%= trade.fee.positive? ? number_to_currency(trade.fee) : "—" %></td>
</tr>
