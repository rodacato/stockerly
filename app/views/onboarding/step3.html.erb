<%# Onboarding Step 3 — Complete / Welcome %>

<div class="max-w-[1000px] mx-auto px-4 py-8 md:py-12">
  <%# Progress Bar %>
  <div class="mb-12">
    <div class="flex justify-between items-center mb-3">
      <span class="text-sm font-semibold uppercase tracking-wider text-primary">Step 3 of 3: Finalized</span>
      <span class="text-sm font-bold text-emerald-600 dark:text-emerald-400">100% Complete</span>
    </div>
    <div class="w-full h-3 bg-slate-200 dark:bg-slate-800 rounded-full overflow-hidden">
      <div class="h-full bg-emerald-500 w-full rounded-full"></div>
    </div>
  </div>

  <%# Success Hero %>
  <div class="text-center mb-10">
    <div class="inline-flex items-center justify-center w-20 h-20 bg-primary/10 rounded-full mb-6">
      <span class="material-symbols-outlined text-primary text-5xl">celebration</span>
    </div>
    <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-4 text-slate-900 dark:text-white">You're all set!</h1>
    <p class="text-slate-600 dark:text-slate-400 text-lg max-w-2xl mx-auto">
      Welcome to <span class="font-bold text-primary">Stockerly</span>. Your investment workspace is configured and ready for action.
    </p>
  </div>

  <%# Summary Card %>
  <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl p-6 shadow-sm mb-12 max-w-2xl mx-auto">
    <div class="flex items-center gap-4">
      <div class="bg-primary/10 p-3 rounded-lg">
        <span class="material-symbols-outlined text-primary">task_alt</span>
      </div>
      <div>
        <h3 class="font-bold text-lg text-slate-900 dark:text-white">Profile Summary</h3>
        <p class="text-slate-600 dark:text-slate-400">You're following <span class="font-semibold text-slate-900 dark:text-white">2 markets</span> and <span class="font-semibold text-slate-900 dark:text-white">5 stocks</span>.</p>
      </div>
    </div>
  </div>

  <%# Dashboard Preview Mockup %>
  <div class="mb-16">
    <h2 class="text-2xl font-bold mb-8 text-center text-slate-900 dark:text-white">Take a quick tour of your new dashboard</h2>
    <div class="relative bg-slate-100 dark:bg-slate-800/50 p-6 md:p-10 rounded-2xl border border-slate-200 dark:border-slate-700 overflow-hidden shadow-inner">
      <div class="grid grid-cols-12 gap-4">
        <%# Main Content Mock %>
        <div class="col-span-12 md:col-span-8 bg-white dark:bg-slate-900 p-4 rounded-xl shadow-sm border border-slate-200 dark:border-slate-800 min-h-[200px]">
          <div class="flex justify-between mb-4">
            <div class="h-5 bg-slate-200 dark:bg-slate-700 rounded w-1/3"></div>
            <div class="h-5 bg-slate-200 dark:bg-slate-700 rounded-full w-10"></div>
          </div>
          <div class="space-y-4">
            <div class="flex justify-between items-center"><div class="h-3 bg-slate-100 dark:bg-slate-800 rounded w-1/4"></div><div class="h-3 bg-emerald-100 dark:bg-emerald-900/30 rounded w-12"></div></div>
            <div class="flex justify-between items-center"><div class="h-3 bg-slate-100 dark:bg-slate-800 rounded w-1/3"></div><div class="h-3 bg-rose-100 dark:bg-rose-900/30 rounded w-12"></div></div>
            <div class="flex justify-between items-center"><div class="h-3 bg-slate-100 dark:bg-slate-800 rounded w-1/4"></div><div class="h-3 bg-emerald-100 dark:bg-emerald-900/30 rounded w-12"></div></div>
          </div>
        </div>
        <%# Side Widget Mock %>
        <div class="col-span-12 md:col-span-4 space-y-4">
          <div class="bg-white dark:bg-slate-900 p-4 rounded-xl shadow-sm border border-slate-200 dark:border-slate-800 min-h-[90px]">
            <div class="h-4 bg-slate-200 dark:bg-slate-700 rounded w-1/2 mb-3"></div>
            <div class="h-8 bg-primary/10 rounded w-3/4"></div>
          </div>
          <div class="bg-white dark:bg-slate-900 p-4 rounded-xl shadow-sm border border-slate-200 dark:border-slate-800 min-h-[90px]">
            <div class="h-4 bg-slate-200 dark:bg-slate-700 rounded w-2/3 mb-3"></div>
            <div class="h-6 bg-slate-100 dark:bg-slate-800 rounded w-full"></div>
          </div>
        </div>
      </div>
      <div class="absolute inset-0 pointer-events-none bg-gradient-to-t from-slate-100/50 dark:from-slate-900/50 to-transparent"></div>
    </div>
  </div>

  <%# Final CTA %>
  <div class="flex flex-col items-center gap-6">
    <%= link_to dashboard_path, class: "flex min-w-[280px] items-center justify-center rounded-xl h-14 px-8 bg-primary text-white text-lg font-bold shadow-lg shadow-primary/30 hover:bg-primary/90 transition-all" do %>
      <span>Go to Dashboard</span>
      <span class="material-symbols-outlined ml-2">arrow_forward</span>
    <% end %>
  </div>
</div>
