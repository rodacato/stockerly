<%# Onboarding Step 2 — Pick stocks to follow %>

<main class="flex-1 flex flex-col items-center py-10 px-4">
  <div class="w-full max-w-2xl bg-white dark:bg-slate-900 rounded-xl shadow-sm border border-slate-200 dark:border-slate-800 overflow-hidden"
       data-controller="onboarding-form">
    <%# Progress Header %>
    <div class="p-6 border-b border-slate-100 dark:border-slate-800">
      <div class="flex items-center justify-between mb-2">
        <span class="text-sm font-semibold text-primary uppercase tracking-wider">Step 2 of 3</span>
        <span class="text-sm font-bold text-slate-900 dark:text-white">66% Complete</span>
      </div>
      <div class="h-2 w-full bg-primary/10 rounded-full overflow-hidden">
        <div class="h-full bg-primary w-2/3 rounded-full"></div>
      </div>
    </div>

    <%# Step Title %>
    <div class="px-8 pt-8 pb-4 text-center">
      <h1 class="text-2xl font-bold text-slate-900 dark:text-white mb-2">Pick your first stocks to follow</h1>
      <p class="text-slate-500 dark:text-slate-400">Add at least 3 to your watchlist to personalize your dashboard.</p>
    </div>

    <%# Stock List — from @assets loaded by Onboarding::LoadAssetCatalog %>
    <div class="px-4 pb-8">
      <div class="space-y-1">
        <% @assets.each do |asset| %>
          <% up = asset.change_percent_24h.to_f >= 0 %>
          <div class="flex items-center justify-between p-4 rounded-xl transition-colors border border-transparent hover:bg-primary/5"
               data-controller="onboarding-select"
               data-onboarding-select-onboarding-form-outlet="[data-controller='onboarding-form']"
               data-onboarding-select-asset-id-value="<%= asset.id %>"
               data-selected="false">
            <div class="flex items-center gap-4">
              <%= render "components/asset_badge", asset: asset, size: "lg" %>
              <div>
                <h4 class="font-semibold text-slate-900 dark:text-white"><%= asset.name %></h4>
                <p class="text-xs text-slate-500"><%= asset.exchange || asset.asset_type.humanize %></p>
              </div>
            </div>
            <div class="flex items-center gap-8">
              <div class="text-right">
                <div class="font-bold text-slate-900 dark:text-white"><%= number_to_currency(asset.current_price || 0) %></div>
                <div class="text-xs font-medium <%= up ? 'text-emerald-600' : 'text-rose-600' %> flex items-center justify-end">
                  <span class="material-symbols-outlined text-xs"><%= up ? 'arrow_drop_up' : 'arrow_drop_down' %></span><%= "#{up ? '+' : ''}#{number_to_percentage(asset.change_percent_24h || 0, precision: 2)}" %>
                </div>
              </div>
              <button type="button"
                      class="w-10 h-10 rounded-full flex items-center justify-center border-2 border-primary/20 text-primary hover:bg-primary hover:text-white transition-all"
                      data-role="toggle-btn"
                      data-action="click->onboarding-select#toggle">
                <span class="material-symbols-outlined">add</span>
              </button>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <%# Footer Navigation %>
    <div class="p-6 bg-slate-50 dark:bg-slate-900/50 border-t border-slate-100 dark:border-slate-800">
      <div class="flex items-center justify-between mb-6">
        <div class="flex items-center gap-2">
          <span class="material-symbols-outlined text-slate-400" data-onboarding-form-target="counterIcon">radio_button_unchecked</span>
          <span class="text-sm font-semibold text-slate-900 dark:text-white" data-onboarding-form-target="counter">0 of 3 minimum selected</span>
        </div>
        <%= link_to "Skip for now", onboarding_step3_path, class: "text-sm font-medium text-primary hover:underline" %>
      </div>
      <div class="flex items-center justify-between">
        <%= link_to onboarding_step1_path, class: "flex items-center gap-1 text-sm font-medium text-slate-500 hover:text-primary transition-colors" do %>
          <span class="material-symbols-outlined text-sm">arrow_back</span>
          Back
        <% end %>

        <form action="<%= complete_onboarding_path %>" method="post">
          <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
          <div data-onboarding-form-target="hiddenInputs"></div>
          <button type="submit"
                  class="bg-primary hover:bg-primary/90 text-white font-bold py-3 px-10 rounded-xl transition-all shadow-lg shadow-primary/25 flex items-center gap-2 opacity-50 cursor-not-allowed"
                  data-onboarding-form-target="submitBtn"
                  data-action="click->onboarding-form#submit"
                  disabled>
            Continue
            <span class="material-symbols-outlined text-lg">arrow_forward</span>
          </button>
        </form>
      </div>
    </div>
  </div>
</main>
