<%# Usage: render "components/alert_event", ticker: "AAPL", message: "Price crossed $180", time_ago: "2m ago", severity: :triggered, direction: :up %>
<% severity ||= :triggered %>
<% direction ||= :up %>
<% border_color = case severity.to_sym
   when :triggered then (direction.to_sym == :up ? 'border-l-emerald-500' : 'border-l-rose-500')
   else 'border-l-slate-300 dark:border-l-slate-600'
   end %>
<% badge_classes = case severity.to_sym
   when :triggered then 'bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400'
   else 'bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400'
   end %>

<div class="border-l-4 <%= border_color %> pl-4 py-3 pr-3 rounded-r-lg hover:translate-x-1 transition-transform bg-white dark:bg-slate-900/50">
  <div class="flex items-start justify-between mb-1">
    <div class="flex items-center gap-2">
      <span class="text-sm font-black text-slate-900 dark:text-white"><%= ticker %></span>
      <span class="px-2 py-0.5 rounded-full text-[10px] font-bold uppercase <%= badge_classes %>">
        <%= severity.to_s.capitalize %>
      </span>
    </div>
    <span class="text-[10px] text-slate-400"><%= time_ago %></span>
  </div>
  <p class="text-xs text-slate-600 dark:text-slate-400"><%= message %></p>
</div>
