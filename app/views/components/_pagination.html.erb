<%# Usage: render "components/pagination", current_page: 1, total_pages: 482, total_count: 4821, per_page: 10 %>
<% current_page ||= 1 %>
<% total_pages ||= 1 %>
<% total_count ||= 0 %>
<% per_page ||= 10 %>
<% start_item = (current_page - 1) * per_page + 1 %>
<% end_item = [current_page * per_page, total_count].min %>

<div class="flex flex-col sm:flex-row items-center justify-between gap-4 pt-4">
  <p class="text-sm text-slate-500 dark:text-slate-400">
    Showing <span class="font-bold text-slate-900 dark:text-white"><%= start_item %>-<%= end_item %></span> of
    <span class="font-bold text-slate-900 dark:text-white"><%= number_with_delimiter(total_count) %></span> results
  </p>
  <div class="flex items-center gap-1">
    <button class="px-3 py-1.5 text-sm font-medium rounded-lg <%= current_page == 1 ? 'text-slate-300 dark:text-slate-600 cursor-not-allowed' : 'text-slate-600 dark:text-slate-300 hover:bg-primary/10' %>" <%= 'disabled' if current_page == 1 %>>
      Previous
    </button>
    <% pages_to_show = [1, 2, 3, total_pages].uniq.sort %>
    <% pages_to_show.each_with_index do |page, i| %>
      <% if i > 0 && page > pages_to_show[i-1] + 1 %>
        <span class="px-2 text-slate-400">&hellip;</span>
      <% end %>
      <button class="size-9 text-sm font-medium rounded-lg <%= page == current_page ? 'bg-primary text-white' : 'text-slate-600 dark:text-slate-300 hover:bg-primary/10' %>">
        <%= page %>
      </button>
    <% end %>
    <button class="px-3 py-1.5 text-sm font-medium rounded-lg <%= current_page == total_pages ? 'text-slate-300 dark:text-slate-600 cursor-not-allowed' : 'text-slate-600 dark:text-slate-300 hover:bg-primary/10' %>">
      Next
    </button>
  </div>
</div>
