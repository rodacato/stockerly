<%# Usage: render "components/market_status_indicator", name: "NYSE", status: :open %>
<% is_open = status.to_sym == :open %>

<div class="flex items-center justify-between py-3">
  <span class="text-sm font-medium text-slate-600 dark:text-slate-300"><%= name %></span>
  <div class="flex items-center gap-2">
    <span class="h-2 w-2 rounded-full <%= is_open ? 'bg-emerald-500 animate-pulse' : 'bg-slate-400' %>"></span>
    <span class="text-xs font-bold uppercase tracking-wider <%= is_open ? 'text-emerald-600 dark:text-emerald-400' : 'text-slate-400' %>">
      <%= is_open ? 'Open' : 'Closed' %>
    </span>
  </div>
</div>
