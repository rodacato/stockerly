<%# Usage: render "components/log_severity_badge", severity: "success" %>
<%# Supported: success, error, warning, info %>
<%
  config = {
    "success"  => { bg: "bg-emerald-100 dark:bg-emerald-900/30", text: "text-emerald-700 dark:text-emerald-400", icon: "check_circle" },
    "error"    => { bg: "bg-rose-100 dark:bg-rose-900/30",       text: "text-rose-700 dark:text-rose-400",       icon: "error" },
    "warning"  => { bg: "bg-amber-100 dark:bg-amber-900/30",     text: "text-amber-700 dark:text-amber-400",     icon: "warning" },
    "info"     => { bg: "bg-blue-100 dark:bg-blue-900/30",       text: "text-blue-700 dark:text-blue-400",       icon: "info" }
  }
  c = config[severity.to_s] || config["info"]
%>
<span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold <%= c[:bg] %> <%= c[:text] %>">
  <span class="material-symbols-outlined text-sm"><%= c[:icon] %></span>
  <%= severity.to_s.capitalize %>
</span>
