<%# Usage: render "components/feature_card", icon: "trending_up", title: "Trend Analysis", description: "..." %>
<div class="bg-white dark:bg-slate-900 p-8 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm hover:shadow-xl transition-all group">
