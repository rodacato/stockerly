    <span class="material-symbols-outlined text-3xl"><%= icon %></span>
  </div>
  <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-3"><%= title %></h3>
  <p class="text-slate-600 dark:text-slate-400 leading-relaxed"><%= description %></p>
</div>
