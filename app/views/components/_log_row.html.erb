<%# Usage: render "components/log_row", severity: "success", task: "FX Rate Update", module_name: "Finance", timestamp: "2 mins ago", duration: "1.2s", action_label: "View Details" %>
<% action_label ||= "View Details" %>
<tr class="border-b border-slate-100 dark:border-slate-800 hover:bg-slate-50 dark:hover:bg-slate-800/30 transition-colors">
  <td class="px-6 py-4">
    <%= render "components/log_severity_badge", severity: severity %>
  </td>
  <td class="px-6 py-4">
    <p class="text-sm font-bold text-slate-900 dark:text-white"><%= task %></p>
  </td>
  <td class="px-6 py-4">
    <span class="text-sm text-slate-500"><%= module_name %></span>
  </td>
  <td class="px-6 py-4">
    <span class="text-sm text-slate-500"><%= timestamp %></span>
  </td>
  <td class="px-6 py-4">
    <span class="text-sm font-mono text-slate-600 dark:text-slate-300"><%= duration %></span>
  </td>
  <td class="px-6 py-4 text-right">
    <button class="text-sm font-medium text-primary hover:text-primary/80 transition-colors"><%= action_label %></button>
  </td>
</tr>
