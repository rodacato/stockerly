# Database (devcontainer defaults)
DATABASE_HOST=db
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# Rails
RAILS_ENV=development
RAILS_MAX_THREADS=5

# Active Record Encryption (generate with: bin/rails db:encryption:init)
# ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=
# ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=
# ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=

# External API keys (optional — also configurable via Admin panel)
# POLYGON_API_KEY=             # news, prices, earnings — https://polygon.io/dashboard/signup
# COINGECKO_API_KEY=           # crypto prices — https://www.coingecko.com/en/api/pricing (free demo key)
# EXCHANGERATE_API_KEY=        # FX rates — https://app.exchangerate-api.com/sign-up
# ALPHA_VANTAGE_API_KEY=       # fundamentals sync (free: 25 req/day) — https://www.alphavantage.co/support/#api-key
# BANXICO_API_TOKEN=           # CETES auction data — https://www.banxico.org.mx/SieAPIRest/service/v1/token

# Deployment (only needed for Kamal deploy)
# SECRET_KEY_BASE=        # generate with: bin/rails secret
# DATABASE_URL=
# POSTGRES_PASSWORD=
# HOST_IP=
# KAMAL_REGISTRY_PASSWORD=
