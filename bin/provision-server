#!/usr/bin/env bash
# Provision a fresh Ubuntu VPS for Kamal deployment with Cloudflare Tunnel.
# Usage: ssh root@YOUR_SERVER_IP < bin/provision-server
set -euo pipefail

echo "==> Updating system packages..."
apt-get update && apt-get upgrade -y

echo "==> Setting up 2GB swap..."
if [ ! -f /swapfile ]; then
  fallocate -l 2G /swapfile
  chmod 600 /swapfile
  mkswap /swapfile
  swapon /swapfile
  echo "/swapfile none swap sw 0 0" >> /etc/fstab
  echo "vm.swappiness=10" >> /etc/sysctl.conf
  sysctl -p
  echo "    Swap created."
else
  echo "    Swap already exists, skipping."
fi

echo "==> Configuring firewall (UFW)..."
apt-get install -y ufw
ufw default deny incoming
ufw default allow outgoing
ufw allow 22/tcp   # SSH (for Kamal deployments)
ufw --force enable
echo "    Firewall enabled: only SSH (22) open. HTTP/HTTPS handled by Cloudflare Tunnel."

echo "==> Installing Docker..."
if ! command -v docker &> /dev/null; then
  curl -fsSL https://get.docker.com | sh
  systemctl enable docker
  systemctl start docker
  echo "    Docker installed."
else
  echo "    Docker already installed, skipping."
fi

echo "==> Installing cloudflared..."
if ! command -v cloudflared &> /dev/null; then
  curl -fsSL https://pkg.cloudflare.com/cloudflare-main.gpg \
    | tee /usr/share/keyrings/cloudflare-main.gpg >/dev/null
  echo "deb [signed-by=/usr/share/keyrings/cloudflare-main.gpg] https://pkg.cloudflare.com/cloudflared $(lsb_release -cs) main" \
    | tee /etc/apt/sources.list.d/cloudflared.list
  apt-get update
  apt-get install -y cloudflared
  echo "    cloudflared installed."
else
  echo "    cloudflared already installed, skipping."
fi

echo "==> Creating deploy user..."
if ! id "deploy" &>/dev/null; then
  adduser --disabled-password --gecos "Deploy" deploy
  usermod -aG docker deploy
  mkdir -p /home/deploy/.ssh
  chmod 700 /home/deploy/.ssh
  # Copy root's authorized_keys so the same SSH key works for deploy
  if [ -f /root/.ssh/authorized_keys ]; then
    cp /root/.ssh/authorized_keys /home/deploy/.ssh/authorized_keys
    chmod 600 /home/deploy/.ssh/authorized_keys
    chown -R deploy:deploy /home/deploy/.ssh
  fi
  echo "    deploy user created and added to docker group."
else
  # Ensure deploy user is in docker group even if already exists
  usermod -aG docker deploy
  echo "    deploy user already exists, ensured docker group membership."
fi

echo "==> Installing curl and git..."
apt-get install -y curl git

echo "==> Setting timezone to UTC..."
timedatectl set-timezone UTC

echo "==> Enabling automatic security updates..."
apt-get install -y unattended-upgrades
dpkg-reconfigure -f noninteractive unattended-upgrades

echo ""
echo "============================================"
echo "  Server provisioned!"
echo "============================================"
echo ""
echo "Next steps:"
echo "  1. Add your SSH public key to /home/deploy/.ssh/authorized_keys"
echo "  2. Create a Cloudflare Tunnel in Zero Trust dashboard"
echo "  3. Install the tunnel on this server:"
echo "     cloudflared service install <TUNNEL_TOKEN>"
echo "  4. Run 'kamal setup' from your local machine"
echo ""
