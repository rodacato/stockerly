#!/bin/bash
# Pre-commit hook to prevent accidental secret leaks
# Install with: bin/setup-hooks

set -e

RED='\033[0;31m'
NC='\033[0m'

# Patterns that likely indicate leaked secrets
PATTERNS=(
  'PRIVATE KEY'
  'password\s*=\s*["\x27][^"\x27]+'
  'api[_-]?key\s*=\s*["\x27][^"\x27]+'
  'secret[_-]?key\s*=\s*["\x27][^"\x27]+'
  'token\s*=\s*["\x27][^"\x27]+'
  'BEGIN RSA'
  'BEGIN DSA'
  'BEGIN EC'
  'BEGIN OPENSSH'
  'sk-[a-zA-Z0-9]{20,}'
  'ghp_[a-zA-Z0-9]{36}'
  'gho_[a-zA-Z0-9]{36}'
  'github_pat_[a-zA-Z0-9_]{82}'
)

# Files to always skip
SKIP_FILES='\.enc$|\.lock$|pre-commit$|SECURITY\.md$|\.example$'

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

# If gitleaks is installed locally, run a stronger staged-diff scan.
if command -v gitleaks >/dev/null 2>&1; then
  if ! git diff --cached --no-color | gitleaks stdin --redact --config=.gitleaks.toml >/dev/null 2>&1; then
    echo -e "${RED}Blocked: gitleaks detected a potential secret in staged changes${NC}"
    echo "Review findings with: gitleaks git --redact --config .gitleaks.toml"
    exit 1
  fi
fi

FOUND=0

for FILE in $STAGED_FILES; do
  # Skip binary, encrypted, and excluded files
  if echo "$FILE" | grep -qE "$SKIP_FILES"; then
    continue
  fi

  for PATTERN in "${PATTERNS[@]}"; do
    if git diff --cached "$FILE" | grep -qiE "$PATTERN"; then
      if [ $FOUND -eq 0 ]; then
        echo -e "${RED}Possible secret detected in staged files:${NC}"
        FOUND=1
      fi
      echo -e "  ${RED}$FILE${NC} matches pattern: $PATTERN"
      break
    fi
  done
done

if [ $FOUND -ne 0 ]; then
  echo ""
  echo "If this is a false positive, commit with: git commit --no-verify"
  exit 1
fi

# Check for .env files being committed
for FILE in $STAGED_FILES; do
  if echo "$FILE" | grep -qE '\.env($|\.)' && ! echo "$FILE" | grep -qE '\.example$'; then
    echo -e "${RED}Blocked: $FILE looks like an environment file with secrets${NC}"
    echo "If intentional, commit with: git commit --no-verify"
    exit 1
  fi
done
