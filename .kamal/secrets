# Secrets are read from environment variables.
# In CI/CD, GitHub Actions injects them from the "production" Environment.
# Locally, you can use .kamal/secret-files/ or export them manually.

KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD
HOST_IP=$HOST_IP

# Rails
SECRET_KEY_BASE=$SECRET_KEY_BASE
POSTGRES_PASSWORD=$POSTGRES_PASSWORD
DATABASE_URL="postgresql://stockerly:${POSTGRES_PASSWORD}@stockerly-postgres:5432/stockerly_production"

# Active Record Encryption
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=$ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=$ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=$ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT

# External API keys
POLYGON_API_KEY=$POLYGON_API_KEY
COINGECKO_API_KEY=$COINGECKO_API_KEY
EXCHANGERATE_API_KEY=$EXCHANGERATE_API_KEY
